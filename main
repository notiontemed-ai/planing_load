const SHEET_SCHEDULE_SOURCE = 'График';
const SHEET_DOCTOR_SCHEDULE = 'Обработанный график';
const SHEET_EMPLOYEES = 'Сотрудники';
const SHEET_REQUESTS = 'Заявки';
const SHEET_PROCESSED_REQUESTS = 'Обработанные заявки';
const SHEET_EXCLUSIONS = 'Исключения';
const SHEET_DISCOUNTS = 'Скидки';
const MENU_NAME = 'TEMED';
const GMAIL_QUERY = 'label:графики-и-заявки-из-1с';
const TARGET_FOLDER_ID = '1LlZSRquXr11iSqLPg4OESmy883vuVpK1';
const PROP_LAST_PROCESSED_MESSAGE_ID = 'LAST_IMPORTED_GMAIL_MESSAGE_ID';
const SEARCH_BATCH_SIZE = 20;
const FL2_SYSTEM_MARKER = '__SYSTEM_TIMESTAMP__';
const FL2_PROCESSED_REQUESTS_CURRENT_DAY_HEADER = 'CurrentDate';
const BITRIX_WEBHOOK_URL = 'https://n8n-x3.tech.temed.ru/webhook/d90a3413-9505-4281-aa7d-49082ae3e1e8/rozxjWwnHbUByCltdXLLfntCxzxNGqGnonwTIHVBaRHYKd/v1/message';
const BITRIX_CHAT_ID_DEFAULT = 228956;
const WEB_APP_EXEC_URL = 'https://script.google.com/macros/s/AKfycbwdqMgb5ru80hQ_2JSz6iULVAIGVwUVejKfKjaO7vdTnlziKorvjD9tUxuxJsDOMgoggw/exec';

const TIME_TYPE_MAP = {
  'Рабочее время': 'Приемные часы',
  'ТОЛЬКО ДЛЯ ПП': 'Приемные часы',
  'Нет приема, курсовики !': 'Процедурные часы',
  'Обед': 'Обед',
};

function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu(MENU_NAME)
    .addItem('Загрузить исходные XLSX на диск', 'importLatestLabeledXlsxToSheetsInteractive')
    .addItem('Обработать исходные данные', 'processSourceData')
    .addItem('Обработать данные с диска', 'processSourceDataFromDrive')
    .addSeparator()
    .addItem('Сформировать план загрузки 3/7 дней', 'buildForwardLoadReport')
    .addItem('Сформировать план загрузки 3/7 дней по всем клиникам', 'buildForwardLoadReportAllBranches')
    .addSeparator()
    .addItem('Обновить скидки по плану', 'updateDiscountsByPlan')
    .addItem('Отправить скидки', 'sendDiscountsEmails')
    .addSeparator()
    .addItem('Собрать общий план', 'buildOverallForecastReport')
    .addSeparator()
    .addSubMenu(
      SpreadsheetApp.getUi()
        .createMenu('Триггеры')
        .addItem('Агрегаторы: скидки + письмо', 'processSourceDataFromDriveTriggerAggregatorsPrepareData')
        .addItem('Филиалы + общий план + скидки + письма', 'processSourceDataFromDriveTriggerBranchesOverallAndDiscounts')
    )
    .addSeparator()
    .addItem('Архивировать план (ежедневно)', 'archivePlanReportsDaily')
    .addToUi();

}

function importLatestLabeledXlsxToSheetsInteractive() {
  return importLatestLabeledXlsxToSheets({ interactive: true, throwOnError: true });
}

function processSourceData(options) {
  const opts = options || {};
  const silent = opts.silent === true;
  buildDoctorSchedule();
  sendUpdatedScheduleBitrixMessage_();
  if (!silent) {
    SpreadsheetApp.getActive().toast('Исходные данные (график + заявки) обработаны', MENU_NAME, 5);
  }
}

function sendMessageToBitrixChat(text, chatIdOverride) {
  const chatId = Number(chatIdOverride || BITRIX_CHAT_ID_DEFAULT);
  const payload = { type: 'chat', id: chatId, message: bitrixMessageText_(text) };
  const options = {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true,
  };
  const response = UrlFetchApp.fetch(BITRIX_WEBHOOK_URL, options);
  const code = response.getResponseCode();
  const body = response.getContentText() || '';

  if (code < 200 || code >= 300) {
    throw new Error(`Bitrix HTTP ${code}. chatId=${chatId}. body=${body}`);
  }

  if (body && /"error"\s*:|^\s*error\b|failed|exception/i.test(body)) {
    throw new Error(`Bitrix response contains error. chatId=${chatId}. body=${body}`);
  }

  return { code: code, body: body };
}

function bitrixMessageText_(text) {
  return String(text || '')
    .replace(/<a\s+href="([^"]+)">([^<]+)<\/a>/gi, '[URL=$1]$2[/URL]')
    .replace(/<b>/gi, '[B]')
    .replace(/<\/b>/gi, '[/B]')
    .replace(/<i>/gi, '[I]')
    .replace(/<\/i>/gi, '[/I]')
    .replace(/<u>/gi, '[U]')
    .replace(/<\/u>/gi, '[/U]')
    .replace(/<s>/gi, '[S]')
    .replace(/<\/s>/gi, '[/S]')
    .replace(/<br\s*\/?>/gi, '\n')
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>');
}

function sendUpdatedScheduleBitrixMessage_() {
  const links = [
    {
      title: 'Агрегаторы: скидки + письмо',
      description: 'Обновляет скидки и отправляет рассылку для агрегаторов.',
      action: 'aggregators_prepare_data',
    },
    {
      title: 'Филиалы + общий план + скидки + письма',
      description: 'Обновляет планы по филиалам, общий план и запускает рассылки.',
      action: 'branches_overall_and_discounts',
    },
  ];

  const lines = [
    '<b>Исходные данные обновлены</b>',
    `Лист "${SHEET_DOCTOR_SCHEDULE}" обновлен.`,
    '',
  ];

  links.forEach((link, idx) => {
    const runUrl = `${WEB_APP_EXEC_URL}?action=${encodeURIComponent(link.action)}`;
    lines.push(`${idx + 1}. <b>${link.title}</b> — ${link.description}`);
    lines.push(`   <a href="${runUrl}">Запустить</a>`);
  });

  sendMessageToBitrixChat(lines.join('\n'), BITRIX_CHAT_ID_DEFAULT);
}

function processSourceDataFromDrive(options) {
  const opts = options || {};
  const interactive = opts.interactive !== false;
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    const imported = importLatestSourceSheetsFromDrive_(TARGET_FOLDER_ID);
    processSourceData({ silent: !interactive });
    notifyExecutionResult_(
      'Готово.\n' +
        `Обновлен лист "${SHEET_REQUESTS}" из файла: ${imported.requestsFileName}\n` +
        `Обновлен лист "${SHEET_SCHEDULE_SOURCE}" из файла: ${imported.scheduleFileName}`,
      interactive
    );
  } catch (error) {
    Logger.log(error && error.stack ? error.stack : error);
    notifyExecutionResult_('Ошибка: ' + error.message, interactive);
    throw error;
  } finally {
    lock.releaseLock();
  }
}

function notifyExecutionResult_(message, interactive) {
  if (interactive) {
    SpreadsheetApp.getUi().alert(message);
    return;
  }
  Logger.log(message);
}

function importLatestLabeledXlsxToSheets(options) {
  const opts = options || {};
  const interactive = opts.interactive === true;
  const throwOnError = opts.throwOnError === true || interactive;
  const lock = LockService.getScriptLock();
  lock.waitLock(30000);

  try {
    const latestMessage = findLatestMessage_(GMAIL_QUERY, SEARCH_BATCH_SIZE);
    if (!latestMessage) {
      notifyExecutionResult_('Писем по запросу не найдено.', interactive);
      return { status: 'skipped', reason: 'no_messages' };
    }

    const messageId = latestMessage.getId();
    const props = PropertiesService.getScriptProperties();
    const lastProcessedMessageId = props.getProperty(PROP_LAST_PROCESSED_MESSAGE_ID);

    if (lastProcessedMessageId === messageId) {
      notifyExecutionResult_('Последнее письмо уже обработано.', interactive);
      return { status: 'skipped', reason: 'already_processed' };
    }

    const attachments = latestMessage.getAttachments({
      includeInlineImages: false,
      includeAttachments: true,
    });

    const xlsxAttachments = attachments.filter(isXlsxAttachment_);

    if (!xlsxAttachments.length) {
      props.setProperty(PROP_LAST_PROCESSED_MESSAGE_ID, messageId);
      notifyExecutionResult_('В последнем письме нет XLSX-вложений.', interactive);
      return { status: 'skipped', reason: 'no_xlsx_attachments' };
    }

    const createdFiles = [];

    for (const attachment of xlsxAttachments) {
      const originalName = attachment.getName() || 'attachment.xlsx';
      const baseName = originalName.replace(/\.xlsx$/i, '');
      const blob = attachment.copyBlob().setName(originalName);

      const resource = {
        name: baseName,
        parents: [TARGET_FOLDER_ID],
        mimeType: 'application/vnd.google-apps.spreadsheet',
      };

      const createdFile = Drive.Files.create(resource, blob, {
        fields: 'id,name,webViewLink',
      });

      createdFiles.push(createdFile.name);
    }

    props.setProperty(PROP_LAST_PROCESSED_MESSAGE_ID, messageId);

    notifyExecutionResult_(
      'Готово.\n' +
      'Импортировано файлов: ' + createdFiles.length + '\n\n' +
      createdFiles.join('\n'),
      interactive
    );
    return { status: 'imported', importedFiles: createdFiles.length };
  } catch (error) {
    Logger.log(error && error.stack ? error.stack : error);
    notifyExecutionResult_('Ошибка: ' + error.message, interactive);
    if (throwOnError) {
      throw error;
    }
    return { status: 'error', errorMessage: error.message };
  } finally {
    lock.releaseLock();
  }
}

function findLatestMessage_(query, batchSize) {
  const threads = GmailApp.search(query, 0, batchSize);
  let latestMessage = null;
  let latestTimestamp = -1;

  for (const thread of threads) {
    const messages = thread.getMessages();
    for (const message of messages) {
      const ts = message.getDate().getTime();
      if (ts > latestTimestamp) {
        latestTimestamp = ts;
        latestMessage = message;
      }
    }
  }

  return latestMessage;
}

function importLatestSourceSheetsFromDrive_(folderId) {
  const requestsFile = findLatestSpreadsheetFileByKeywords_(folderId, ['заявк']);
  const scheduleFile = findLatestSpreadsheetFileByKeywords_(folderId, ['график']);

  if (!requestsFile) {
    throw new Error('Не найден актуальный файл "Заявки" в папке Google Drive.');
  }
  if (!scheduleFile) {
    throw new Error('Не найден актуальный файл "Графики" в папке Google Drive.');
  }

  const ss = SpreadsheetApp.getActive();
  copySheetDataFromFileToActiveSheet_(ss, requestsFile.id, SHEET_REQUESTS);
  copySheetDataFromFileToActiveSheet_(ss, scheduleFile.id, SHEET_SCHEDULE_SOURCE);

  return {
    requestsFileName: requestsFile.name,
    scheduleFileName: scheduleFile.name,
  };
}

function findLatestSpreadsheetFileByKeywords_(folderId, keywords) {
  const folder = DriveApp.getFolderById(folderId);
  const files = folder.getFiles();
  let latest = null;

  while (files.hasNext()) {
    const file = files.next();
    const name = str_(file.getName());
    const lowerName = name.toLowerCase();
    const isSpreadsheet = str_(file.getMimeType()) === MimeType.GOOGLE_SHEETS;
    const matchKeyword = keywords.some((kw) => lowerName.indexOf(str_(kw).toLowerCase()) >= 0);
    if (!isSpreadsheet || !matchKeyword) continue;

    const updated = file.getLastUpdated();
    if (!latest || updated.getTime() > latest.updatedAt.getTime()) {
      latest = {
        id: file.getId(),
        name,
        updatedAt: updated,
      };
    }
  }

  return latest;
}

function copySheetDataFromFileToActiveSheet_(activeSpreadsheet, sourceFileId, targetSheetName) {
  const sourceSpreadsheet = SpreadsheetApp.openById(sourceFileId);
  const sourceSheet = sourceSpreadsheet.getSheetByName(targetSheetName) || sourceSpreadsheet.getSheets()[0];
  if (!sourceSheet) {
    throw new Error(`В файле ${sourceSpreadsheet.getName()} нет листов для импорта "${targetSheetName}"`);
  }

  const sourceValues = sourceSheet.getDataRange().getValues();
  const targetSheet = getOrCreateSheet_(activeSpreadsheet, targetSheetName);
  targetSheet.clearContents();
  if (!sourceValues.length || !sourceValues[0].length) return;
  targetSheet.getRange(1, 1, sourceValues.length, sourceValues[0].length).setValues(sourceValues);
}

function isXlsxAttachment_(attachment) {
  const name = String(attachment.getName() || '').toLowerCase();
  const contentType = String(attachment.getContentType() || '').toLowerCase();

  return (
    name.endsWith('.xlsx') ||
    contentType === 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
  );
}

function buildDoctorSchedule() {
  const ss = SpreadsheetApp.getActive();
  const source = ss.getSheetByName(SHEET_SCHEDULE_SOURCE);
  if (!source) {
    throw new Error(`Не найден лист "${SHEET_SCHEDULE_SOURCE}"`);
  }

  const rows = getSheetObjectsDisplay_(source);
  const requestsSheet = ss.getSheetByName(SHEET_REQUESTS);
  const requestRows = requestsSheet ? getSheetObjectsDisplay_(requestsSheet) : [];
  const excludedEmployees = getExcludedEmployeesSet_(ss);
  const employeeRegistry = getEmployeeRegistry_(ss);
  const currentDayKey = detectCurrentDayFromSourceRequestsRows_(requestRows);
  if (!currentDayKey) throw new Error('Не найдены выполненные заявки для определения актуальной даты');
  const rangeStartKey = addDaysToDayKey_(currentDayKey, -42);
  const rangeEndKey = addDaysToDayKey_(currentDayKey, 7);
  const requestsRangeEndKey = addDaysToDayKey_(currentDayKey, 8);

  const grouped = new Map();
  let sourceGraphMaxCreatedAt = new Date(0);

  rows.forEach((row, idx) => {
    const employee = str_(row['Сотрудник']);
    const cabinet = str_(row['Кабинет']);
    const cabinetType = detectCabinetType_(cabinet);
    const isCabinetRow = Boolean(cabinetType);
    const rowBranch = str_(row['Филиал']);
    const rowDate = toDate_(row['Дата']);
    const rowStart = parseTimeToMinutes_(row['Время начала']);
    const rowEnd = parseTimeToMinutes_(row['Время окончания']);
    const rowTimeKind = str_(row['Вид времени']);
    let scheduleDecision = 'included';
    let scheduleReason = '';
    if (!isCabinetRow) {
      if (!employee || excludedEmployees.has(employee)) {
        scheduleDecision = 'excluded';
        scheduleReason = 'excluded_employee';
      } else if (hasStandaloneTestWord_(employee)) {
        scheduleDecision = 'excluded';
        scheduleReason = 'test_name';
      } else if (!employeeRegistry.allowed.has(employee)) {
        scheduleDecision = 'excluded';
        scheduleReason = 'employee_not_allowed';
        employeeRegistry.unassignedFound.add(employee);
      }
    } else if (employee && excludedEmployees.has(employee)) {
      scheduleDecision = 'excluded';
      scheduleReason = 'excluded_employee';
    } else if (employee && hasStandaloneTestWord_(employee)) {
      scheduleDecision = 'excluded';
      scheduleReason = 'test_name';
    }

    if (scheduleDecision === 'included' && !isDayKeyInRangeInclusive_(parseLocalDayKey_(rowDate) || parseLocalDayKey_(row['Дата']), rangeStartKey, rangeEndKey)) {
      scheduleDecision = 'excluded';
      scheduleReason = 'date_out_of_range';
    }
    if (scheduleDecision === 'included' && (rowStart === null || rowEnd === null || rowEnd <= rowStart)) {
      scheduleDecision = 'excluded';
      scheduleReason = 'invalid_interval';
    }

    if (scheduleDecision !== 'included') return;
    const date = rowDate;
    const dateLabel = formatDateDDMMYYYY_(date || row['Дата']);
    const branch = rowBranch;
    const start = rowStart;
    const end = rowEnd;
    const timeKind = rowTimeKind;
    const sourceCreatedAt = toDate_(row['Дата создания']);
    if (sourceCreatedAt && sourceCreatedAt > sourceGraphMaxCreatedAt) sourceGraphMaxCreatedAt = sourceCreatedAt;

    const createdAtRaw = row['Дата создания'];
    const createdAt = toDate_(createdAtRaw) || new Date(0);
    const createdAtSort = sortableDateTime_(createdAtRaw) || createdAt.getTime();
    const createdAtLabel = formatDateTimeDDMMYYYY_(createdAtRaw) || formatDateTimeDDMMYYYY_(createdAt);

    if (!date || !dateLabel || !branch || start === null || end === null || !timeKind) return;

    const key = [dateKey_(date), branch, employee, cabinet].join('|');
    if (!grouped.has(key)) grouped.set(key, []);

    grouped.get(key).push({
      date,
      dateLabel,
      branch,
      employee,
      cabinet,
      cabinetType,
      start,
      end,
      timeKind,
      timeType: mapTimeType_(timeKind),
      createdAt,
      createdAtSort,
      createdAtLabel,
      eventId: str_(row['Идентификатор события']),
      rowOrder: idx,
    });
  });

  const resolved = [];
  grouped.forEach((items) => {
    resolved.push(...resolveIntervals_(items));
  });

  resolved.sort((a, b) => {
    if (a.branch !== b.branch) return a.branch.localeCompare(b.branch, 'ru');
    const cmpDate = a.date.getTime() - b.date.getTime();
    if (cmpDate !== 0) return cmpDate;
    if (a.employee !== b.employee) return a.employee.localeCompare(b.employee, 'ru');
    return a.start - b.start;
  });

  const compacted = mergeAdjacentSlotsByType_(resolved);

  const target = getOrCreateSheet_(ss, SHEET_DOCTOR_SCHEDULE);
  target.clearContents();
  const header = [
    'Дата', 'Филиал', 'Сотрудник', 'Кабинет', 'Время начала', 'Время окончания', 'Вид времени', 'Тип времени', 'Дата создания', 'Идентификатор события',
  ];
  target.getRange(1, 1, 1, header.length).setValues([header]);

  const now = new Date();
  const minMarkerTime = sourceGraphMaxCreatedAt.getTime() > 0 ? sourceGraphMaxCreatedAt.getTime() + 1000 : 0;
  const markerDate = new Date(Math.max(now.getTime(), minMarkerTime));
  const markerRow = [FL2_SYSTEM_MARKER, '', '', '', '', '', '', '', formatDateTimeDDMMYYYY_(markerDate), FL2_SYSTEM_MARKER];

  if (compacted.length) {
    const values = compacted.map((r) => [
      r.dateLabel, r.branch, r.employee, r.cabinet || '', minutesToTimeString_(r.start), minutesToTimeString_(r.end), r.timeKind, r.timeType, r.createdAtLabel, r.eventId,
    ]);
    values.push(markerRow);
    target.getRange(2, 1, values.length, header.length).setValues(values);
  } else {
    target.getRange(2, 1, 1, header.length).setValues([markerRow]);
  }

  buildProcessedRequestsSheet_(ss, requestsSheet, employeeRegistry.allowed, excludedEmployees, rangeStartKey, requestsRangeEndKey, currentDayKey, employeeRegistry.unassignedFound);
  saveUnassignedEmployees_(ss, employeeRegistry.unassignedFound);
  SpreadsheetApp.getActive().toast('Обработанные данные сформированы', MENU_NAME, 5);
}

function buildProcessedRequestsSheet_(ss, requestsSheet, allowedEmployees, excludedEmployees, rangeStartKey, rangeEndKey, currentDayKey, unassignedSet) {
  if (!requestsSheet) return;
  const dataRange = requestsSheet.getDataRange();
  const values = dataRange.getValues();
  const displayValues = dataRange.getDisplayValues();
  if (!values.length) return;

  const headers = values[0].map((h) => str_(h));
  const idxStatus = headers.indexOf('Состояние');
  const idxEmployee = headers.indexOf('Сотрудник');
  const idxClient = headers.indexOf('Клиент');
  const idxStart = headers.indexOf('ДатаНачала');
  const idxEnd = headers.indexOf('ДатаОкончания');
  const idxBranch = headers.indexOf('Филиал');
  const idxCreatedAt = headers.indexOf('Дата');

  const excludedOutputHeaders = new Set(['Клиент', 'Примечание', 'ДатаНачала', 'ДатаОкончания']);
  const sourceColumns = [];
  const outHeaders = [];
  headers.forEach((header, idx) => {
    if (excludedOutputHeaders.has(header)) return;
    const outHeader = header === 'Дата' ? 'Дата создания' : header;
    sourceColumns.push({ idx, outHeader });
    outHeaders.push(outHeader);
  });
  const extraHeaders = [
    'Дата',
    'Время начала',
    'Время окончания',
    FL2_PROCESSED_REQUESTS_CURRENT_DAY_HEADER,
  ];
  extraHeaders.forEach((h) => {
    if (outHeaders.indexOf(h) < 0) outHeaders.push(h);
  });

  const idxCabinet = headers.indexOf('Кабинет');

  const rows = values.slice(1).filter((row) => {
    const employee = str_(row[idxEmployee]);
    const client = str_(row[idxClient]);
    const status = str_(row[idxStatus]);
    const startDayKey = parseLocalDayKey_(row[idxStart]) || parseLocalDayKey_(row[headers.indexOf('Дата')]);
    const branch = str_(row[idxBranch]);
    const cabinetType = detectCabinetType_(idxCabinet >= 0 ? row[idxCabinet] : '');
    const isCabinetRequest = Boolean(cabinetType);
    let decision = 'included';
    let reason = '';

    if (!isCabinetRequest) {
      if (!employee || (excludedEmployees && excludedEmployees.has(employee))) {
        decision = 'excluded';
        reason = 'excluded_employee';
      } else if (hasStandaloneTestWord_(employee) || hasStandaloneTestWord_(client)) {
        decision = 'excluded';
        reason = 'test_name';
      } else if (allowedEmployees && !allowedEmployees.has(employee)) {
        decision = 'excluded';
        reason = 'employee_not_allowed';
        if (unassignedSet) unassignedSet.add(employee);
      }
    } else if (employee && ((excludedEmployees && excludedEmployees.has(employee)))) {
      decision = 'excluded';
      reason = 'excluded_employee';
    } else if ((employee && hasStandaloneTestWord_(employee)) || hasStandaloneTestWord_(client)) {
      decision = 'excluded';
      reason = 'test_name';
    }

    if (decision === 'included' && !isAllowedProcessedRequestStatus(status)) {
      decision = 'excluded';
      reason = 'status_not_allowed';
    }
    if (decision === 'included' && isPlannedStatus(status) && startDayKey && currentDayKey && startDayKey < currentDayKey) {
      decision = 'excluded';
      reason = 'planned_before_current_day';
    }
    if (decision === 'included' && !isDayKeyInRangeInclusive_(startDayKey, rangeStartKey, rangeEndKey)) {
      decision = 'excluded';
      reason = 'out_of_range';
    }

    if (decision !== 'included') return false;
    return true;
  });

  rows.sort((a, b) => {
    const ba = str_(a[idxBranch]);
    const bb = str_(b[idxBranch]);
    if (ba !== bb) return ba.localeCompare(bb, 'ru');
    const da = parseLocalDayKey_(a[idxStart]) || '';
    const db = parseLocalDayKey_(b[idxStart]) || '';
    if (da !== db) return da.localeCompare(db);
    const ta = parseTimeToMinutes_(a[headers.indexOf('Время начала')]);
    const tb = parseTimeToMinutes_(b[headers.indexOf('Время начала')]);
    return (ta === null ? 0 : ta) - (tb === null ? 0 : tb);
  });

  const idxCreatedAtOut = outHeaders.indexOf('Дата создания');
  const idxDateOut = outHeaders.indexOf('Дата');
  const idxStartTimeOut = outHeaders.indexOf('Время начала');
  const idxEndTimeOut = outHeaders.indexOf('Время окончания');
  const idxCurrentDayMetaOut = outHeaders.indexOf(FL2_PROCESSED_REQUESTS_CURRENT_DAY_HEADER);

  const outRows = rows.map((row) => {
    const sourceRowIdx = values.indexOf(row);
    const displayRow = sourceRowIdx >= 0 ? displayValues[sourceRowIdx] : [];
    const parts = splitRequestDateTimeParts_(displayRow[idxStart], displayRow[idxEnd], row[idxStart], row[idxEnd]);
    const item = new Array(outHeaders.length).fill('');
    sourceColumns.forEach((col) => {
      const outIdx = outHeaders.indexOf(col.outHeader);
      if (outIdx >= 0) item[outIdx] = row[col.idx];
    });
    if (idxCreatedAtOut >= 0) item[idxCreatedAtOut] = idxCreatedAt >= 0 ? row[idxCreatedAt] : '';
    if (idxDateOut >= 0) item[idxDateOut] = parts.date || '';
    if (idxStartTimeOut >= 0) item[idxStartTimeOut] = parts.startTime || '';
    if (idxEndTimeOut >= 0) item[idxEndTimeOut] = parts.endTime || '';
    return item;
  });

  const markerRow = new Array(outHeaders.length).fill('');
  if (idxCurrentDayMetaOut >= 0) markerRow[idxCurrentDayMetaOut] = dayKeyToDateText_(currentDayKey);

  outRows.push(markerRow);

  const target = getOrCreateSheet_(ss, SHEET_PROCESSED_REQUESTS);
  target.clearContents();
  target.getRange(1, 1, 1, outHeaders.length).setValues([outHeaders]);
  if (outRows.length) {
    target.getRange(2, 1, outRows.length, outHeaders.length).setValues(outRows);
  }
  applyProcessedRequestsIntervalColumnFormat_(target, outHeaders);
}

function mergeIntervals_(intervals) {
  if (!intervals.length) return [];
  const sorted = [...intervals].sort((a, b) => a.start - b.start || a.end - b.end);
  const merged = [Object.assign({}, sorted[0])];

  for (let i = 1; i < sorted.length; i += 1) {
    const current = sorted[i];
    const last = merged[merged.length - 1];
    if (current.start <= last.end) {
      if (current.end > last.end) last.end = current.end;
    } else {
      merged.push(Object.assign({}, current));
    }
  }

  return merged;
}

function resolveIntervals_(records) {
  const points = new Set();
  records.forEach((r) => {
    points.add(r.start);
    points.add(r.end);
  });

  const sorted = [...points].sort((a, b) => a - b);
  const segments = [];

  for (let i = 0; i < sorted.length - 1; i += 1) {
    const segStart = sorted[i];
    const segEnd = sorted[i + 1];
    if (segEnd <= segStart) continue;

    const candidates = records.filter((r) => r.start < segEnd && r.end > segStart);
    if (!candidates.length) continue;

    candidates.sort((a, b) => {
      const cmp = a.createdAtSort - b.createdAtSort;
      if (cmp !== 0) return cmp;
      return a.rowOrder - b.rowOrder;
    });

    const winner = candidates[candidates.length - 1];
    const previous = segments[segments.length - 1];

    if (
      previous &&
      previous.end === segStart &&
      previous.timeKind === winner.timeKind &&
      previous.timeType === winner.timeType &&
      previous.createdAtSort === winner.createdAtSort &&
      previous.eventId === winner.eventId &&
      str_(previous.cabinet) === str_(winner.cabinet)
    ) {
      previous.end = segEnd;
    } else {
      segments.push({
        date: winner.date,
        dateLabel: winner.dateLabel,
        branch: winner.branch,
        employee: winner.employee,
        cabinet: winner.cabinet || '',
        cabinetType: winner.cabinetType || '',
        start: segStart,
        end: segEnd,
        timeKind: winner.timeKind,
        timeType: winner.timeType,
        createdAt: winner.createdAt,
        createdAtSort: winner.createdAtSort,
        createdAtLabel: winner.createdAtLabel,
        eventId: winner.eventId,
      });
    }
  }

  return segments;
}

function mergeAdjacentSlotsByType_(rows) {
  if (!rows.length) return [];
  const merged = [];

  rows.forEach((row) => {
    const prev = merged[merged.length - 1];
    const canMerge = prev
      && dateKey_(prev.date) === dateKey_(row.date)
      && prev.branch === row.branch
      && prev.employee === row.employee
      && str_(prev.cabinet) === str_(row.cabinet)
      && prev.timeType === row.timeType
      && prev.end === row.start;

    if (!canMerge) {
      merged.push(Object.assign({}, row));
      return;
    }

    prev.end = row.end;
    if (row.createdAtSort > prev.createdAtSort) {
      prev.createdAt = row.createdAt;
      prev.createdAtSort = row.createdAtSort;
      prev.createdAtLabel = row.createdAtLabel;
    }

    const eventIds = [str_(prev.eventId), str_(row.eventId)].filter((v) => v);
    prev.eventId = [...new Set(eventIds)].join(', ');
  });

  return merged;
}

function getEmployeeRegistry_(ss) {
  const unassignedFound = new Set();
  const allowed = new Set();

  const doctors = getDoctorsSetFromEmployeesSheet_(ss);
  const massage = getMassageSetFromEmployeesSheet_(ss);
  const ft = getFtSetFromEmployeesSheet_(ss);

  doctors.forEach((n) => allowed.add(n));
  massage.forEach((n) => allowed.add(n));
  ft.forEach((n) => allowed.add(n));

  return { allowed, unassignedFound };
}

function saveUnassignedEmployees_(ss, unassignedSet) {
  const sheet = ss.getSheetByName(SHEET_EMPLOYEES);
  if (!sheet) return;

  const maxCols = sheet.getLastColumn() || 1;
  const lastRow = Math.max(sheet.getLastRow(), 1);
  const values = sheet.getRange(1, 1, lastRow, maxCols).getDisplayValues();
  const header = values[0].map((v) => str_(v));

  let unassignedCol = header.findIndex((h) => h.toLowerCase() === 'нераспределенные');
  if (unassignedCol < 0) {
    unassignedCol = maxCols;
    sheet.getRange(1, unassignedCol + 1).setValue('Нераспределенные');
    // перечитаем диапазон после добавления колонки заголовка
    const newMaxCols = sheet.getLastColumn();
    const newLastRow = Math.max(sheet.getLastRow(), 1);
    values.length = 0;
    values.push(...sheet.getRange(1, 1, newLastRow, newMaxCols).getDisplayValues());
  }

  const rowCount = values.length - 1;
  const categorized = new Set();
  const currentUnassigned = [];

  for (let r = 1; r < values.length; r += 1) {
    const row = values[r];
    row.forEach((cell, c) => {
      const name = str_(cell);
      if (!name) return;
      if (c === unassignedCol) {
        currentUnassigned.push(name);
      } else {
        categorized.add(name);
      }
    });
  }

  // Чистим нераспределенных: удаляем тех, кто уже есть в любых других столбцах
  const keptUnassigned = currentUnassigned.filter((name, idx, arr) => !categorized.has(name) && arr.indexOf(name) === idx);

  // Добавляем новых только если их нет ни в одном столбце (включая нераспределенных)
  const knownAll = new Set([...categorized, ...keptUnassigned]);
  const incoming = unassignedSet ? [...unassignedSet].map((v) => str_(v)).filter((v) => v) : [];
  const toAppend = incoming.filter((name, idx, arr) => !knownAll.has(name) && arr.indexOf(name) === idx).sort((a, b) => a.localeCompare(b, 'ru'));
  const finalUnassigned = [...keptUnassigned, ...toAppend];

  const colIndex = unassignedCol + 1;
  const clearRows = Math.max(rowCount, finalUnassigned.length, 1);
  sheet.getRange(2, colIndex, clearRows, 1).clearContent();
  if (finalUnassigned.length) {
    sheet.getRange(2, colIndex, finalUnassigned.length, 1).setValues(finalUnassigned.map((v) => [v]));
  }
}

function getExcludedEmployeesSet_(ss) {
  const set = new Set();
  const sheet = ss.getSheetByName(SHEET_EXCLUSIONS);
  if (!sheet) return set;

  const rows = getSheetObjectsDisplay_(sheet);
  rows.forEach((row) => {
    const employee = str_(row['Сотрудник']);
    if (employee) set.add(employee);
  });
  return set;
}

function hasStandaloneTestWord_(value) {
  return str_(value).toLowerCase().indexOf('тест') >= 0;
}

function formatDateDDMMYYYY_(value) {
  const date = toDate_(value);
  if (!date) return '';
  return Utilities.formatDate(date, FL2_TIMEZONE, 'dd.MM.yyyy');
}

function normalizeDateToTimezoneStart_(value) {
  const date = toDate_(value);
  if (!date) return null;
  const parts = Utilities.formatDate(date, FL2_TIMEZONE, 'yyyy-MM-dd').split('-').map((v) => Number(v));
  return new Date(parts[0], parts[1] - 1, parts[2]);
}

function getWeekdayNameRu_(value) {
  const date = toDate_(value);
  if (!date) return '';
  return ['воскресенье', 'понедельник', 'вторник', 'среда', 'четверг', 'пятница', 'суббота'][date.getDay()] || '';
}

function formatReportPeriodLabel_(startDate, endDate) {
  const start = toDate_(startDate);
  const end = toDate_(endDate);
  if (!start || !end) return '';
  return `${formatDateDDMMYYYY_(start)} (${getWeekdayNameRu_(start)}) - ${formatDateDDMMYYYY_(end)} (${getWeekdayNameRu_(end)})`;
}

function computeReportPeriodFromReferenceMoment_(referenceMoment, baseDayDate) {
  const timestamp = toDate_(referenceMoment);
  if (!timestamp) return null;
  const referenceDate = normalizeDateToTimezoneStart_(baseDayDate || timestamp);
  if (!referenceDate) return null;
  const referenceHour = Number(Utilities.formatDate(timestamp, FL2_TIMEZONE, 'H'));
  const startDate = addDays(referenceDate, 1);
  const endDate = addDays(startDate, 6);
  return {
    referenceMoment: timestamp,
    referenceHour,
    startDate,
    endDate,
    anchorDate: addDays(startDate, -1),
    label: formatReportPeriodLabel_(startDate, endDate),
  };
}

function buildHorizonPeriodLabels_(reportPeriodLabel) {
  const dates = str_(reportPeriodLabel).match(/\d{2}\.\d{2}\.\d{4}/g) || [];
  const startDate = dates.length ? toDate_(dates[0]) : null;
  const endDate = dates.length > 1 ? toDate_(dates[1]) : (startDate ? addDays(startDate, 6) : null);
  return {
    startDate,
    endDate,
    period3dLabel: startDate ? formatReportPeriodLabel_(startDate, addDays(startDate, 2)) : '',
    period7dLabel: startDate && endDate ? formatReportPeriodLabel_(startDate, endDate) : str_(reportPeriodLabel),
  };
}

function formatDateTimeDDMMYYYY_(value) {
  const date = toDate_(value);
  if (!date) return '';
  return Utilities.formatDate(date, FL2_TIMEZONE, 'dd.MM.yyyy HH:mm:ss');
}

function sortableDateTime_(value) {
  const date = toDate_(value);
  if (!date) return null;
  return Number(Utilities.formatDate(date, FL2_TIMEZONE, 'yyyyMMddHHmmss'));
}

function mapTimeType_(timeKind) {
  return TIME_TYPE_MAP[timeKind] || 'Прочие часы';
}

function getSheetObjects_(sheet) {
  const values = sheet.getDataRange().getValues();
  if (values.length < 2) return [];
  const headers = values[0].map((h) => str_(h));
  return values.slice(1).map((row) => {
    const item = {};
    headers.forEach((h, i) => {
      item[h] = row[i];
    });
    return item;
  });
}

function getSheetObjectsDisplay_(sheet) {
  const values = sheet.getDataRange().getDisplayValues();
  if (values.length < 2) return [];
  const headers = values[0].map((h) => str_(h));
  return values.slice(1).map((row) => {
    const item = {};
    headers.forEach((h, i) => {
      item[h] = row[i];
    });
    return item;
  });
}

function getSheetObjectsByBranch_(sheet, branchName, useDisplayValues) {
  const branch = str_(branchName);
  if (!branch) return [];

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow < 2 || lastCol < 1) return [];

  const readFn = useDisplayValues ? 'getDisplayValues' : 'getValues';
  const headers = sheet.getRange(1, 1, 1, lastCol)[readFn]()[0].map((h) => str_(h));
  const branchIdx = headers.indexOf('Филиал');
  if (branchIdx < 0) return [];

  const branchColumn = sheet.getRange(2, branchIdx + 1, lastRow - 1, 1).getDisplayValues().map((r) => str_(r[0]));
  const ranges = [];
  let start = null;

  for (let i = 0; i < branchColumn.length; i += 1) {
    const isMatch = branchColumn[i] === branch;
    if (isMatch && start === null) start = i;
    if (!isMatch && start !== null) {
      ranges.push({ startIdx: start, endIdx: i - 1 });
      start = null;
    }
  }
  if (start !== null) ranges.push({ startIdx: start, endIdx: branchColumn.length - 1 });
  if (!ranges.length) return [];

  const out = [];
  ranges.forEach((r) => {
    const rowStart = r.startIdx + 2;
    const rowCount = r.endIdx - r.startIdx + 1;
    const values = sheet.getRange(rowStart, 1, rowCount, lastCol)[readFn]();
    out.push(...mapRowsToObjects_(headers, values));
  });
  return out;
}

function mapRowsToObjects_(headers, rows) {
  return rows.map((row) => {
    const item = {};
    headers.forEach((h, i) => {
      item[h] = row[i];
    });
    return item;
  });
}

function getOrCreateSheet_(ss, name) {
  return ss.getSheetByName(name) || ss.insertSheet(name);
}

function deleteSheetIfExists_(ss, name) {
  const sheet = ss.getSheetByName(name);
  if (sheet) ss.deleteSheet(sheet);
}

function parseTimeToMinutes_(value) {
  if (value === '' || value === null || value === undefined) return null;
  if (typeof value === 'number') {
    const dayMinutes = Math.round((value % 1) * 24 * 60);
    return ((dayMinutes % 1440) + 1440) % 1440;
  }
  if (Object.prototype.toString.call(value) === '[object Date]' && !Number.isNaN(value.getTime())) {
    return value.getHours() * 60 + value.getMinutes();
  }

  const str = String(value).trim();
  const match = str.match(/^(\d{1,2}):(\d{2})(?::\d{2})?$/);
  if (!match) return null;

  const h = Number(match[1]);
  const m = Number(match[2]);
  if (h < 0 || h > 23 || m < 0 || m > 59) return null;
  return h * 60 + m;
}

function minutesToTimeString_(minutes) {
  const h = Math.floor(minutes / 60);
  const m = minutes % 60;
  return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
}

function toDate_(value) {
  if (Object.prototype.toString.call(value) === '[object Date]' && !Number.isNaN(value.getTime())) {
    return value;
  }
  if (value === '' || value === null || value === undefined) return null;

  if (typeof value === 'number') {
    const epochMs = Math.round((value - 25569) * 86400 * 1000);
    const parsedNum = new Date(epochMs);
    if (!Number.isNaN(parsedNum.getTime())) return parsedNum;
  }

  const normalized = str_(value);
  const isoDate = normalized.match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (isoDate) {
    const year = Number(isoDate[1]);
    const month = Number(isoDate[2]);
    const day = Number(isoDate[3]);
    const parsedIsoDate = new Date(year, month - 1, day, 0, 0, 0, 0);
    if (!Number.isNaN(parsedIsoDate.getTime())) return parsedIsoDate;
  }

  const ruDateTime = normalized.match(/^(\d{1,2})\.(\d{1,2})\.(\d{4})(?:[ T](\d{1,2}):(\d{2})(?::(\d{2}))?)?$/);
  if (ruDateTime) {
    const day = Number(ruDateTime[1]);
    const month = Number(ruDateTime[2]);
    const year = Number(ruDateTime[3]);
    const hour = Number(ruDateTime[4] !== undefined ? ruDateTime[4] : 12);
    const minute = Number(ruDateTime[5] || 0);
    const second = Number(ruDateTime[6] || 0);
    const parsedRu = new Date(year, month - 1, day, hour, minute, second, 0);
    if (!Number.isNaN(parsedRu.getTime())) return parsedRu;
  }

  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return null;
  return parsed;
}

function dateKey_(date) {
  if (!date) return '';
  return Utilities.formatDate(date, FL2_TIMEZONE, 'yyyy-MM-dd');
}

function parseLocalDayKey_(value) {
  if (value === '' || value === null || value === undefined) return '';
  const text = str_(value);
  if (text) {
    const ruMatch = text.match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/);
    if (ruMatch) {
      const day = Number(ruMatch[1]);
      const month = Number(ruMatch[2]);
      const year = Number(ruMatch[3]);
      if (day >= 1 && day <= 31 && month >= 1 && month <= 12) {
        return `${String(year).padStart(4, '0')}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      }
    }
    const isoMatch = text.match(/^(\d{4})-(\d{2})-(\d{2})$/);
    if (isoMatch) return `${isoMatch[1]}-${isoMatch[2]}-${isoMatch[3]}`;
  }
  const parsed = toDate_(value);
  if (!parsed) return '';
  return Utilities.formatDate(parsed, FL2_TIMEZONE, 'yyyy-MM-dd');
}

function dayKeyToDate_(dayKey) {
  const m = str_(dayKey).match(/^(\d{4})-(\d{2})-(\d{2})$/);
  if (!m) return null;
  return new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
}

function dayKeyToDateText_(dayKey) {
  const d = dayKeyToDate_(dayKey);
  return d ? formatDateDDMMYYYY_(d) : '';
}

function addDaysToDayKey_(dayKey, days) {
  const d = dayKeyToDate_(dayKey);
  if (!d) return '';
  return dateKey_(addDays(d, days));
}

function isDayKeyInRangeInclusive_(dayKey, startKey, endKey) {
  const d = str_(dayKey);
  const s = str_(startKey);
  const e = str_(endKey);
  if (!d || !s || !e) return false;
  return d >= s && d <= e;
}

function str_(value) {
  if (value === null || value === undefined) return '';
  return String(value).trim();
}

function round1_(value) {
  return Math.round(value * 10) / 10;
}
var FL2_SHEET_MAILING = 'Отправка';
var FL2_SHEET_OVERALL_FORECAST = 'Общий план';
var FL2_SHEET_DISCOUNTS_EMAIL_STATE = 'Состояние рассылки скидок';
var FL2_SHEET_BATCH_SERVICE = 'Сервис план';
var FL2_PLAN_ARCHIVE_SPREADSHEET_ID = '1w9PLSlkxbJX6kigWtxYZElTyCLTM1ceDriA29yeFBgc';
var FL2_TIMEZONE = 'Europe/Moscow';
var FL2_ARCHIVE_CATEGORY_SHEET_MAP = {
  doctor: 'Архив Врачи',
  massage: 'Архив Массажисты',
  ft: 'Архив ФТ',
  physio: 'Архив Физиотерапия',
};
var FL2_ARCHIVE_BASELINE_CACHE = null;
function buildForwardLoadReport() {
  const ss = SpreadsheetApp.getActive();
  const ui = SpreadsheetApp.getUi();

  const precheckPrep = prepareForwardLoadInput_(ss, { persistUnassigned: false });

  const branches = getBranchesFromEmployeesSheet_(ss);
  const promptText = `Введите филиал (точно как в данных):
${branches.join('\n')}`;
  const response = ui.prompt('План загрузки 3/7 дней', promptText, ui.ButtonSet.OK_CANCEL);
  if (response.getSelectedButton() !== ui.Button.OK) return;

  const selectedBranch = str_(response.getResponseText());
  if (!selectedBranch) throw new Error('Филиал не выбран');
  if (!branches.includes(selectedBranch)) throw new Error(`Филиал "${selectedBranch}" не найден в листе "Сотрудники"`);

  const prep = prepareForwardLoadInput_(ss, { selectedBranch, persistUnassigned: false, currentDay: precheckPrep.currentDay });
  const currentDay = buildForwardLoadReportForBranch_(ss, selectedBranch, prep);
  const sendAnswer = ui.alert('План загрузки', 'Сделать рассылку отчёта?', ui.ButtonSet.YES_NO);
  if (sendAnswer === ui.Button.YES) {
    sendForwardReportEmail(ss, selectedBranch, currentDay);
  }
  refreshDiscountsAfterPlanUpdate_();
  SpreadsheetApp.getActive().toast('План загрузки сформирован', MENU_NAME, 5);
}

function buildForwardLoadReportAllBranches() {
  const ui = SpreadsheetApp.getUi();
  const prep = prepareForwardLoadInput_(SpreadsheetApp.getActive(), { persistUnassigned: false });
  const sendAnswer = ui.alert('Пакетный план по клиникам', 'После завершения очереди отправить письма автоматически?', ui.ButtonSet.YES_NO);
  const sendEmails = sendAnswer === ui.Button.YES;
  runForwardLoadReportAllBranchesCore_({ sendEmails, currentDay: prep.currentDay });
}

function runForwardLoadReportsDirect_(options) {
  const opts = options || {};
  const ss = SpreadsheetApp.getActive();
  const sendEmails = opts.sendEmails === true;
  const includeBaseline = opts.includeBaseline !== false;

  const doctorScheduleSheet = ss.getSheetByName(SHEET_DOCTOR_SCHEDULE);
  const processedRequestsSheet = ss.getSheetByName(SHEET_PROCESSED_REQUESTS);
  if (!doctorScheduleSheet || !processedRequestsSheet) {
    throw new Error('Проверьте наличие листов: Обработанный график, Обработанные заявки');
  }
  ensureDoctorScheduleFresh(ss);

  const prep = prepareForwardLoadInput_(ss, { persistUnassigned: false });
  const currentDay = opts.currentDay || prep.currentDay;
  const branches = prep.branches || [];
  const errors = [];

  const sharedExcluded = prep.excludedEmployees;
  const sharedRegistry = { allowed: prep.allowedEmployees, unassignedFound: prep.unassignedEmployees };
  const sharedDoctorsSet = prep.doctorsSet;
  const sharedMassageSet = prep.massageSet;
  const sharedFtSet = prep.ftSet;

  branches.forEach((branchName) => {
    const branch = str_(branchName);
    try {
      const branchPrep = prepareForwardLoadInput_(ss, {
        selectedBranch: branch,
        currentDay,
        persistUnassigned: false,
        excludedEmployees: sharedExcluded,
        employeeRegistry: sharedRegistry,
        doctorsSet: sharedDoctorsSet,
        massageSet: sharedMassageSet,
        ftSet: sharedFtSet,
      });
      buildForwardLoadReportForBranch_(ss, branch, branchPrep, {
        includeBaseline,
      });
      if (sendEmails) {
        sendForwardReportEmail(ss, branch, currentDay);
      }
    } catch (e) {
      const err = `${branch || '(пусто)'}: ${e && e.message ? e.message : String(e)}`;
      errors.push(err);
    }
  });

  if (errors.length) {
    throw new Error(`Построение планов по клиникам завершено с ошибками: ${errors.slice(0, 3).join(' | ')}`);
  }
  return {
    branchCount: branches.length,
  };
}

function runForwardLoadReportAllBranchesCore_(options) {
  const opts = options || {};
  const ss = SpreadsheetApp.getActive();
  const sendEmails = opts.sendEmails !== false;
  const includeBaseline = opts.includeBaseline !== false;
  const refreshDiscountsAfter = opts.refreshDiscountsAfter === true;

  const doctorScheduleSheet = ss.getSheetByName(SHEET_DOCTOR_SCHEDULE);
  const processedRequestsSheet = ss.getSheetByName(SHEET_PROCESSED_REQUESTS);
  if (!doctorScheduleSheet || !processedRequestsSheet) {
    throw new Error('Проверьте наличие листов: Обработанный график, Обработанные заявки');
  }
  ensureDoctorScheduleFresh(ss);

  const prep = prepareForwardLoadInput_(ss, { persistUnassigned: false });
  const currentDay = opts.currentDay || prep.currentDay;
  const branches = prep.branches || [];
  const errors = [];

  const sharedExcluded = prep.excludedEmployees;
  const sharedRegistry = { allowed: prep.allowedEmployees, unassignedFound: prep.unassignedEmployees };
  const sharedDoctorsSet = prep.doctorsSet;
  const sharedMassageSet = prep.massageSet;
  const sharedFtSet = prep.ftSet;

  branches.forEach((branchName) => {
    const branch = str_(branchName);
    try {
      const branchPrep = prepareForwardLoadInput_(ss, {
        selectedBranch: branch,
        currentDay,
        persistUnassigned: false,
        excludedEmployees: sharedExcluded,
        employeeRegistry: sharedRegistry,
        doctorsSet: sharedDoctorsSet,
        massageSet: sharedMassageSet,
        ftSet: sharedFtSet,
      });
      buildForwardLoadReportForBranch_(ss, branch, branchPrep, {
        includeBaseline,
      });

      if (sendEmails) {
        sendForwardReportEmail(ss, branch, currentDay);
      }
    } catch (e) {
      const err = `${branch || '(пусто)'}: ${e && e.message ? e.message : String(e)}`;
      errors.push(err);
    }
  });

  const doneMsg = errors.length
    ? `Пакетный план завершён с ошибками: ${errors.slice(0, 3).join(' | ')}`
    : 'Пакетный план по клиникам завершён';

  if (refreshDiscountsAfter) {
    refreshDiscountsAfterPlanUpdate_();
  }
  SpreadsheetApp.getActive().toast(doneMsg, MENU_NAME, 8);
}

function refreshDiscountsAfterPlanUpdate_() {
  try {
    updateDiscountsByPlan({ silent: true });
  } catch (e) {
  }
}

function detectProcessedRequestsMeta_(sheet) {
  if (!sheet) return null;

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow < 2 || lastCol < 1) return null;

  const headers = sheet.getRange(1, 1, 1, lastCol).getDisplayValues()[0].map((h) => str_(h));
  const idxCurrentDay = headers.indexOf(FL2_PROCESSED_REQUESTS_CURRENT_DAY_HEADER);
  if (idxCurrentDay < 0) return null;

  const lastRowValues = sheet.getRange(lastRow, 1, 1, lastCol).getDisplayValues()[0];
  const currentDayKey = parseLocalDayKey_(lastRowValues[idxCurrentDay]);
  if (!currentDayKey) return null;

  return {
    currentDayKey,
  };
}

function ensureProcessedRequestsMeta_(ss) {
  ensureDoctorScheduleFresh(ss);

  let sheet = ss.getSheetByName(SHEET_PROCESSED_REQUESTS);
  let meta = detectProcessedRequestsMeta_(sheet);
  if (meta) return meta;

  buildDoctorSchedule();

  sheet = ss.getSheetByName(SHEET_PROCESSED_REQUESTS);
  meta = detectProcessedRequestsMeta_(sheet);
  if (!meta) {
    throw new Error('Не удалось определить CurrentDate из листа "Обработанные заявки"');
  }

  return meta;
}

function prepareForwardLoadInput_(ss, options) {
  const opts = options || {};

  const scheduleSheet = ss.getSheetByName(SHEET_DOCTOR_SCHEDULE);
  const requestsSheet = ss.getSheetByName(SHEET_PROCESSED_REQUESTS);
  const sourceRequestsSheet = ss.getSheetByName(SHEET_REQUESTS);
  if (!scheduleSheet || !requestsSheet || !sourceRequestsSheet) {
    throw new Error('Проверьте наличие листов: Обработанный график, Обработанные заявки, Заявки');
  }
  ensureDoctorScheduleFresh(ss);

  const excludedEmployees = opts.excludedEmployees ? opts.excludedEmployees : getExcludedEmployeesSet_(ss);
  const employeeRegistry = opts.employeeRegistry ? opts.employeeRegistry : getEmployeeRegistry_(ss);
  const selectedBranch = str_(opts.selectedBranch);

  const processedRequestsMeta = ensureProcessedRequestsMeta_(ss);
  const storedCurrentDayKey = processedRequestsMeta.currentDayKey;

  let incomingCurrentDayKey = str_(opts.currentDayKey);
  if (!incomingCurrentDayKey && opts.currentDay) {
    if (opts.currentDay instanceof Date) {
      incomingCurrentDayKey = parseLocalDayKey_(opts.currentDay);
    } else {
      incomingCurrentDayKey = parseLocalDayKey_(opts.currentDay) || parseLocalDayKey_(new Date(Number(opts.currentDay)));
    }
  }

  if (incomingCurrentDayKey && incomingCurrentDayKey !== storedCurrentDayKey) {
  }

  const currentDayKey = storedCurrentDayKey;
  const currentDay = dayKeyToDate_(currentDayKey);
  if (!currentDayKey || !currentDay || Number.isNaN(currentDay.getTime())) {
    throw new Error('Не найдены выполненные заявки для определения CurrentDate');
  }
  const reportPeriod = computeReportPeriodFromReferenceMoment_(new Date(), currentDay);

  const anchorDayKey = reportPeriod && reportPeriod.anchorDate
    ? parseLocalDayKey_(reportPeriod.anchorDate)
    : addDaysToDayKey_(currentDayKey, -1);
  const rangeStartKey = addDaysToDayKey_(anchorDayKey, -42);
  const rangeEndKey = reportPeriod && reportPeriod.endDate
    ? parseLocalDayKey_(reportPeriod.endDate)
    : addDaysToDayKey_(anchorDayKey, 7);
  const anchorDay = dayKeyToDate_(anchorDayKey);
  const rangeStart = dayKeyToDate_(rangeStartKey);
  const rangeEnd = dayKeyToDate_(rangeEndKey);

  const scheduleSourceRows = selectedBranch
    ? getSheetObjectsByBranch_(scheduleSheet, selectedBranch, true)
    : getSheetObjectsDisplay_(scheduleSheet);

  const scheduleRows = scheduleSourceRows
    .filter((r) => {
      const dKey = parseLocalDayKey_(r['Дата']);
      const emp = str_(r['Сотрудник']);
      const branch = str_(r['Филиал']);
      const cabinetType = detectCabinetType_(r['Кабинет']);
      const isCabinetRow = Boolean(cabinetType);
      if (selectedBranch && branch !== selectedBranch) return false;
      if (!isCabinetRow) {
        if (!emp || !employeeRegistry.allowed.has(emp)) {
          if (emp) employeeRegistry.unassignedFound.add(emp);
          return false;
        }
      }
      return isDayKeyInRangeInclusive_(dKey, rangeStartKey, rangeEndKey);
    })
    .sort((a, b) => {
      const ba = str_(a['Филиал']);
      const bb = str_(b['Филиал']);
      if (ba !== bb) return ba.localeCompare(bb, 'ru');
      const da = toDate_(a['Дата']);
      const db = toDate_(b['Дата']);
      return (da ? da.getTime() : 0) - (db ? db.getTime() : 0);
    });

  const requestSourceRows = selectedBranch
    ? getSheetObjectsByBranch_(requestsSheet, selectedBranch, true)
    : getSheetObjectsDisplay_(requestsSheet);

  const requestRowsRaw = requestSourceRows.filter((r) => {
    const dKey = parseLocalDayKey_(r['Дата']) || parseLocalDayKey_(r['ДатаНачала']);
    const branch = str_(r['Филиал']);
    if (selectedBranch && branch !== selectedBranch) return false;
    return isDayKeyInRangeInclusive_(dKey, rangeStartKey, rangeEndKey);
  });


  const branchesAll = getBranchesFromEmployeesSheet_(ss);
  const branches = selectedBranch ? branchesAll.filter((b) => b === selectedBranch) : branchesAll;
  if (!branches.length) throw new Error('Не удалось определить список филиалов');

  if (!opts || opts.persistUnassigned !== false) {
    saveUnassignedEmployees_(ss, employeeRegistry.unassignedFound);
  }
  return {
    scheduleRows,
    requestRowsRaw,
    branches,
    excludedEmployees,
    currentDay: currentDayKey,
    currentDayKey,
    anchorDay,
    anchorDayKey,
    rangeStart,
    rangeEnd,
    rangeStartKey,
    rangeEndKey,
    reportPeriod,
    allowedEmployees: employeeRegistry.allowed,
    unassignedEmployees: employeeRegistry.unassignedFound,
    doctorsSet: opts && opts.doctorsSet ? opts.doctorsSet : getDoctorsSetFromEmployeesSheet_(ss),
    massageSet: opts && opts.massageSet ? opts.massageSet : getMassageSetFromEmployeesSheet_(ss),
    ftSet: opts && opts.ftSet ? opts.ftSet : getFtSetFromEmployeesSheet_(ss),
  };
}

function buildForwardLoadReportForBranch_(ss, selectedBranch, prep, options) {
  const branchName = str_(selectedBranch);
  if (!branchName) throw new Error('Филиал не задан для пакетного расчета');
  const opts = options || {};
  const includeBaseline = opts.includeBaseline !== false;

  const anchorDay = prep.anchorDay ? new Date(prep.anchorDay.getTime()) : addDays(dayKeyToDate_(prep.currentDayKey || prep.currentDay), -1);
  const anchorDayKey = prep.anchorDayKey || parseLocalDayKey_(anchorDay);

  const filteredScheduleRows = prep.scheduleRows.filter((r) => str_(r['Филиал']) === branchName);
  const filteredRequestRows = prep.requestRowsRaw.filter((r) => str_(r['Филиал']) === branchName);

  const scheduleByDoctorDay = buildReceptionScheduleIndex(filteredScheduleRows, prep.excludedEmployees, prep.allowedEmployees);

  const doctorsSet = prep.doctorsSet || getDoctorsSetFromEmployeesSheet_(ss);
  const massageSet = prep.massageSet || getMassageSetFromEmployeesSheet_(ss);
  const ftSet = prep.ftSet || getFtSetFromEmployeesSheet_(ss);

  const doctorScheduleByDoctorDay = new Map();
  scheduleByDoctorDay.forEach((intervals, key) => {
    const doctor = str_(key.split('|')[2]);
    if (doctorsSet.has(doctor)) doctorScheduleByDoctorDay.set(key, intervals);
  });

  const latestRequests = buildLatestRequests(filteredRequestRows, prep.excludedEmployees, prep.allowedEmployees, prep.unassignedEmployees, prep.rangeStartKey, prep.rangeEndKey);

  const currentPlanDebug = buildCurrentPlanDebugStats_(latestRequests, scheduleByDoctorDay, doctorScheduleByDoctorDay);
  const currentDailyDoctorBuckets = computeWindowDailyBuckets_(anchorDayKey, 7, doctorScheduleByDoctorDay, latestRequests);

  const horizon3 = aggregateWindowMetricsFromDailyBuckets_(anchorDayKey, 3, currentDailyDoctorBuckets);

  const horizon7 = aggregateWindowMetricsFromDailyBuckets_(anchorDayKey, 7, currentDailyDoctorBuckets);

  let baseline3;
  let baseline7;

  const currentDailyAllBuckets = computeWindowDailyBuckets_(anchorDayKey, 7, scheduleByDoctorDay, latestRequests, { includeAllNomenclature: true });

  const horizon3All = aggregateWindowMetricsFromDailyBuckets_(anchorDayKey, 3, currentDailyAllBuckets);

  const horizon7All = aggregateWindowMetricsFromDailyBuckets_(anchorDayKey, 7, currentDailyAllBuckets);

  let baseline3All;
  let baseline7All;

  if (includeBaseline) {
    baseline3 = computeBaselineMetrics(anchorDay, 3, doctorScheduleByDoctorDay, latestRequests, { category: 'doctor' });

    baseline7 = computeBaselineMetrics(anchorDay, 7, doctorScheduleByDoctorDay, latestRequests, { category: 'doctor' });

    baseline3All = computeBaselineMetrics(anchorDay, 3, scheduleByDoctorDay, latestRequests, {
      includeAllNomenclature: true,
      categoryResolver: (employee) => {
        if (massageSet.has(str_(employee))) return 'massage';
        if (ftSet.has(str_(employee))) return 'ft';
        return 'doctor';
      },
    });

    baseline7All = computeBaselineMetrics(anchorDay, 7, scheduleByDoctorDay, latestRequests, {
      includeAllNomenclature: true,
      categoryResolver: (employee) => {
        if (massageSet.has(str_(employee))) return 'massage';
        if (ftSet.has(str_(employee))) return 'ft';
        return 'doctor';
      },
    });
  } else {
    baseline3 = { byBranch: new Map(), byDoctor: new Map() };
    baseline7 = { byBranch: new Map(), byDoctor: new Map() };
    baseline3All = { byBranch: new Map(), byDoctor: new Map() };
    baseline7All = { byBranch: new Map(), byDoctor: new Map() };
  }

  const rowsBranch = mergeForwardRows(horizon3.byBranch, horizon7.byBranch, baseline3.byBranch, baseline7.byBranch);
  const rowsDoctorAll = mergeForwardRows(horizon3.byDoctor, horizon7.byDoctor, baseline3.byDoctor, baseline7.byDoctor);
  const rowsAllNomenclature = mergeForwardRows(horizon3All.byDoctor, horizon7All.byDoctor, baseline3All.byDoctor, baseline7All.byDoctor);

  const rowsDoctor = rowsDoctorAll.filter((r) => doctorsSet.has(str_(r.doctor)));

  const occupiedDoctorsCount = rowsDoctor.filter((r) => (numOrZero_(r && r.c3 && r.c3.occupiedMin) > 0) || (numOrZero_(r && r.c7 && r.c7.occupiedMin) > 0)).length;
  const zeroDoctorsCount = rowsDoctor.filter((r) => numOrZero_(r && r.c3 && r.c3.occupiedMin) === 0 && numOrZero_(r && r.c7 && r.c7.occupiedMin) === 0).length;

  if (currentPlanDebug.participatingRequests > 0 && rowsDoctor.length > 0 && zeroDoctorsCount === rowsDoctor.length) {
    // keep anomaly guard without debug logging
  }

  const massageSummary = aggregateForwardCategorySummary_(rowsAllNomenclature, massageSet);
  const ftSummary = aggregateForwardCategorySummary_(rowsAllNomenclature, ftSet);
  const cabinetSummary = buildCabinetTypeSummary_(anchorDay, filteredScheduleRows, latestRequests, {
    includeBaseline,
  });
  const massageRows = rowsAllNomenclature.filter((r) => massageSet.has(str_(r.doctor)));
  const ftRows = rowsAllNomenclature.filter((r) => ftSet.has(str_(r.doctor)));
  const cabinetRows = buildCabinetRowsByName_(anchorDay, filteredScheduleRows, latestRequests, {
    includeBaseline,
  });

  renderForwardLoadSheet(ss, anchorDay, prep.reportPeriod, branchName, rowsBranch, rowsDoctor, massageSummary, ftSummary, cabinetSummary, massageRows, ftRows, cabinetRows, {
    includeBaseline,
  });

  return prep.currentDay;
}

function buildCurrentPlanDebugStats_(latestRequests, scheduleByDoctorDay, doctorScheduleByDoctorDay) {
  const scheduleKeys = new Set(doctorScheduleByDoctorDay ? doctorScheduleByDoctorDay.keys() : []);
  let matchedRequestScheduleKeys = 0;
  let participatingRequests = 0;
  const uniqueRequestKeys = new Set();

  (latestRequests || []).forEach((r) => {
    if (!r || !r.dayKey) return;
    if (!isActivePlannedStatus(r.status) || !r.isDoctorVisit) return;
    participatingRequests += 1;
    const key = `${str_(r.dayKey)}|${str_(r.branch)}|${str_(r.doctor)}`;
    if (uniqueRequestKeys.has(key)) return;
    uniqueRequestKeys.add(key);
    if (scheduleKeys.has(key)) matchedRequestScheduleKeys += 1;
  });

  return {
    matchedRequestScheduleKeys,
    participatingRequests,
    scheduleKeys: scheduleByDoctorDay ? scheduleByDoctorDay.size : 0,
    doctorScheduleKeys: doctorScheduleByDoctorDay ? doctorScheduleByDoctorDay.size : 0,
  };
}

function getEmployeesSetByHeader_(ss, headerNames, fallbackColIndex) {
  const sheet = ss.getSheetByName(SHEET_EMPLOYEES);
  if (!sheet) throw new Error('Не найден лист "Сотрудники"');
  const values = sheet.getDataRange().getDisplayValues();
  if (!values.length) return new Set();

  const header = values[0].map((h) => str_(h).toLowerCase());
  const names = (headerNames || []).map((h) => str_(h).toLowerCase());
  let col = header.findIndex((h) => names.includes(h));
  if (col < 0 && Number.isInteger(fallbackColIndex) && fallbackColIndex >= 0) col = fallbackColIndex;
  if (col < 0) return new Set();

  return new Set(
    values
      .slice(1)
      .map((row) => str_(row[col]))
      .filter((name) => name)
  );
}

function getDoctorsSetFromEmployeesSheet_(ss) {
  return getEmployeesSetByHeader_(ss, ['врачи', 'врач'], 0);
}

function getMassageSetFromEmployeesSheet_(ss) {
  return getEmployeesSetByHeader_(ss, ['массажисты', 'массажист'], 1);
}

function getFtSetFromEmployeesSheet_(ss) {
  return getEmployeesSetByHeader_(ss, ['фт'], 2);
}

function getBranchesFromEmployeesSheet_(ss) {
  const sheet = ss.getSheetByName(SHEET_EMPLOYEES);
  if (!sheet) throw new Error('Не найден лист "Сотрудники"');
  const values = sheet.getDataRange().getDisplayValues();
  if (!values.length) throw new Error('Лист "Сотрудники" пуст');

  const header = values[0].map((h) => str_(h).toLowerCase());
  let branchCol = header.findIndex((h) => h === 'филиал');
  if (branchCol < 0) {
    throw new Error('В листе "Сотрудники" не найдена колонка "Филиал"');
  }

  const set = new Set();
  values.slice(1).forEach((row) => {
    const b = str_(row[branchCol]);
    if (b) set.add(b);
  });
  const branches = [...set].sort((a, b) => a.localeCompare(b, 'ru'));
  if (!branches.length) throw new Error('В колонке "Филиал" листа "Сотрудники" нет данных');
  return branches;
}

function detectCurrentDayFromSourceRequestsRows_(rows) {
  let maxDayKey = '';
  let maxRow = null;
  const list = Array.isArray(rows) ? rows : [];
  list.forEach((row) => {
    const status = str_(row['Состояние']);
    if (!isCompletedStatus(status)) return;
    const dKey = parseLocalDayKey_(row['ДатаНачала']);
    if (!dKey) return;
    if (!maxDayKey || dKey > maxDayKey) {
      maxDayKey = dKey;
      maxRow = row;
    }
  });
  if (maxDayKey && maxRow) {
  } else {
  }
  return maxDayKey || null;
}
function buildReceptionScheduleIndex(scheduleRows, excludedEmployees, allowedEmployees) {
  const map = new Map();
  scheduleRows.forEach((row) => {
    const dayKey = parseLocalDayKey_(row['Дата']);
    const doctor = str_(row['Сотрудник']);
    if (!doctor || (excludedEmployees && excludedEmployees.has(doctor)) || hasStandaloneTestWord_(doctor)) return;
    if (allowedEmployees && !allowedEmployees.has(doctor)) return;
    const branch = str_(row['Филиал']);
    const type = str_(row['Тип времени']);
    const start = parseTimeToMinutes_(row['Время начала']);
    const end = parseTimeToMinutes_(row['Время окончания']);
    if (!dayKey || !doctor || !branch || !type || start === null || end === null || end <= start) return;
    const key = `${dayKey}|${branch}|${doctor}`;
    if (!map.has(key)) map.set(key, []);
    const interval = { type, start, end };
    map.get(key).push(interval);
  });
  map.forEach((arr, key) => {
    arr.sort((a, b) => a.start - b.start);
  });
  return map;
}
function buildLatestRequests(rows, excludedEmployees, allowedEmployees, unassignedSet, rangeStartKey, rangeEndKey) {
  const latest = new Map();
  rows.forEach((row, idx) => {
    const status = str_(row['Состояние']);
    const id = str_(row['Номер заявки']) || str_(row['Номер']) || str_(row['ID']) || `ROW-${idx}`;
    const doctor = str_(row['Сотрудник']);
    const branch = str_(row['Филиал']);
    const startDate = toDate_(row['ДатаНачала']);
    const endDate = toDate_(row['ДатаОкончания']);
    const intervalParts = normalizeRequestIntervalParts_(row, startDate, endDate);
    const client = str_(row['Клиент']);
    const cabinet = str_(row['Кабинет']);
    const cabinetType = detectCabinetType_(cabinet);
    const isCabinetRequest = Boolean(cabinetType);
    const blockedByCategory = doctor && allowedEmployees && !allowedEmployees.has(doctor);
    if (blockedByCategory && unassignedSet && doctor) unassignedSet.add(doctor);
    const skipByName = isCabinetRequest
      ? ((excludedEmployees && excludedEmployees.has(doctor)) || hasStandaloneTestWord_(doctor) || hasStandaloneTestWord_(client))
      : (!doctor || blockedByCategory || (excludedEmployees && excludedEmployees.has(doctor)) || hasStandaloneTestWord_(doctor) || hasStandaloneTestWord_(client));
    const skipReason = !skipByName
      ? ''
      : (!doctor || blockedByCategory)
        ? 'doctor_not_allowed'
        : (excludedEmployees && excludedEmployees.has(doctor))
          ? 'excluded_employee'
          : 'skip_by_name';
    const nomenclatureRaw = str_(row['Номенклатура']);
    const nomenclature = nomenclatureRaw.toLowerCase();
    const isDoctorVisit = nomenclature.includes('врача');
    const isPrimary = nomenclature.includes('первичный');
    if (!isAllowedProcessedRequestStatus(status)) {
      return;
    }
    const statusDate = toDate_(row['Дата создания']) || toDate_(row['Дата']) || toDate_(row['ДатаНачала']) || new Date(0);
    const statusSort = Number(Utilities.formatDate(statusDate, FL2_TIMEZONE, 'yyyyMMddHHmmss'));
    const prev = latest.get(id);
    if (!prev || statusSort > prev.statusSort || (statusSort === prev.statusSort && idx > prev.idx)) {
      latest.set(id, {
        idx,
        id,
        statusSort,
        status,
        doctor,
        branch: str_(row['Филиал']),
        startDate: dayKeyToDate_(intervalParts.dayKey),
        endDate: dayKeyToDate_(intervalParts.dayKey),
        dayKey: intervalParts.dayKey,
        startMin: intervalParts.startMin,
        endMin: intervalParts.endMin,
        startTime: intervalParts.startTime,
        endTime: intervalParts.endTime,
        nomenclature: nomenclatureRaw,
        isDoctorVisit,
        isPrimary,
        cabinet,
        cabinetType,
        skipByName,
        skipReason,
        intervalError: intervalParts.error,
      });
      const inserted = latest.get(id);
      if (prev) {
        const prevNomenclature = str_(prev.nomenclature);
        if (!inserted.nomenclature && prevNomenclature) inserted.nomenclature = prevNomenclature;
        if (!inserted.nomenclature && prev.isDoctorVisit) inserted.isDoctorVisit = true;
        if (!inserted.nomenclature && prev.isPrimary) inserted.isPrimary = true;
      }
    } else {
    }
  });
  return [...latest.values()].filter((r) => {
    if (r.intervalError) {
      return false;
    }
    if (r.skipByName) {
      return false;
    }
    if (rangeStartKey && rangeEndKey && !isDayKeyInRangeInclusive_(r.dayKey, rangeStartKey, rangeEndKey)) {
      return false;
    }
    return true;
  });
}
function computeWindowDailyBuckets_(anchorDayKey, maxHorizonDays, scheduleByDoctorDay, requests, options) {
  const startDayKey = addDaysToDayKey_(anchorDayKey, 1);
  const endDayKey = addDaysToDayKey_(anchorDayKey, maxHorizonDays);
  const includeAllNomenclature = Boolean(options && options.includeAllNomenclature);
  const dailyBuckets = new Map();

  const scheduleKeysInWindow = new Set();
  scheduleByDoctorDay.forEach((_, key) => {
    const [dKey] = key.split('|');
    if (!isDayKeyInRangeInclusive_(dKey, startDayKey, endDayKey)) return;
    scheduleKeysInWindow.add(key);
  });

  const requestIndex = new Map();
  requests.forEach((r) => {
    if (!isActivePlannedStatus(r.status)) return;
    if (!includeAllNomenclature && !r.isDoctorVisit) return;
    const requestDayKey = str_(r.dayKey);
    if (!isDayKeyInRangeInclusive_(requestDayKey, startDayKey, endDayKey)) return;
    const key = `${requestDayKey}|${r.branch}|${r.doctor}`;
    if (!scheduleKeysInWindow.has(key)) {
      return;
    }
    if (!requestIndex.has(key)) requestIndex.set(key, { intervals: [], reqCount: 0, primaryCount: 0 });
    const entry = requestIndex.get(key);
    entry.intervals.push(requestInterval(r));
    entry.reqCount += 1;
    if (r.isPrimary) entry.primaryCount += 1;
  });

  scheduleByDoctorDay.forEach((intervals, key) => {
    const [dKey, branch, doctor] = key.split('|');
    if (!isDayKeyInRangeInclusive_(dKey, startDayKey, endDayKey)) return;

    const req = requestIndex.get(key) || { intervals: [], reqCount: 0, primaryCount: 0 };
    const reception = mergeIntervals_(intervals.filter((i) => i.type === 'Приемные часы'));
    const nonReception = mergeIntervals_(intervals.filter((i) => i.type !== 'Приемные часы'));
    const occupied = mergeIntervals_(req.intervals);
    const occupiedWithinReception = intersectIntervals(occupied, reception);
    const occupiedWithinNonReception = intersectIntervals(occupied, nonReception);
    const nonReceptionOccupiedMin = sumIntervalsMin(occupiedWithinNonReception);

    if (!reception.length && nonReceptionOccupiedMin <= 0) return;

    const free = subtractIntervals(reception, occupiedWithinReception);
    const metric = {
      receptionMin: sumIntervalsMin(reception) + nonReceptionOccupiedMin,
      occupiedMin: sumIntervalsMin(occupiedWithinReception) + nonReceptionOccupiedMin,
      freeMin: sumIntervalsMin(free),
      freePP: free.reduce((acc, i) => acc + Math.floor((i.end - i.start) / 60), 0),
      reqCount: req.reqCount,
      primaryCount: req.primaryCount,
    };

    if (!dailyBuckets.has(dKey)) dailyBuckets.set(dKey, []);
    dailyBuckets.get(dKey).push({ branch, doctor, metric });
  });

  return dailyBuckets;
}

function aggregateWindowMetricsFromDailyBuckets_(anchorDayKey, horizonDays, dailyBuckets) {
  const startDayKey = addDaysToDayKey_(anchorDayKey, 1);
  const endDayKey = addDaysToDayKey_(anchorDayKey, horizonDays);
  const byBranch = new Map();
  const byDoctor = new Map();

  (dailyBuckets || new Map()).forEach((entries, dKey) => {
    if (!isDayKeyInRangeInclusive_(dKey, startDayKey, endDayKey)) return;
    (entries || []).forEach((entry) => {
      accumulateForward(byBranch, entry.branch, entry.metric, entry.branch, '');
      accumulateForward(byDoctor, `${entry.branch}|${entry.doctor}`, entry.metric, entry.branch, entry.doctor);
    });
  });

  return { byBranch, byDoctor };
}

function computeBaselineMetrics(currentDay, horizonDays, scheduleByDoctorDay, requests, options) {
  const opts = options || {};
  const categoryResolver = typeof opts.categoryResolver === 'function'
    ? opts.categoryResolver
    : () => str_(opts.category || 'doctor');
  const horizonLabel = Number(horizonDays) === 7 ? '7 дней' : '3 дня';

  const byBranch = new Map();
  const byDoctor = new Map();
  const index = loadArchiveBaselineIndex_();
  const seen = new Set();

  scheduleByDoctorDay.forEach((intervals, key) => {
    const parts = str_(key).split('|');
    const branch = str_(parts[1]);
    const doctor = str_(parts[2]);
    if (!branch || !doctor) return;
    const uniq = `${branch}|${doctor}`;
    if (seen.has(uniq)) return;
    seen.add(uniq);

    const category = str_(categoryResolver(doctor, branch)) || 'doctor';
    const metric = getArchiveBaselineMetric_(index, {
      category,
      branch,
      object: doctor,
      horizon: horizonLabel,
      reportDate: currentDay,
      maxObservations: 6,
    });

    byDoctor.set(uniq, { branch, doctor, metrics: metric });
    accumulateForward(byBranch, branch, metric, branch, '');
  });

  return { byBranch, byDoctor };
}
function mergeForwardRows(current3, current7, base3, base7) {
  const keys = new Set([...current3.keys(), ...current7.keys(), ...base3.keys(), ...base7.keys()]);
  const rows = [];
  keys.forEach((key) => {
    const c3 = current3.get(key) || emptyForwardEntry(key);
    const c7 = current7.get(key) || emptyForwardEntry(key);
    const b3 = base3.get(key) || emptyForwardEntry(key);
    const b7 = base7.get(key) || emptyForwardEntry(key);
    const branch = c3.branch || c7.branch || b3.branch || b7.branch || key;
    const doctor = c3.doctor || c7.doctor || b3.doctor || b7.doctor || '';
    rows.push({ key, branch, doctor, c3: c3.metrics, c7: c7.metrics, b3: b3.metrics, b7: b7.metrics });
  });
  rows.sort((a, b) => {
    if (a.branch !== b.branch) return a.branch.localeCompare(b.branch, 'ru');
    return (a.doctor || '').localeCompare(b.doctor || '', 'ru');
  });
  return rows;
}
function renderForwardLoadSheet(ss, currentDay, reportPeriod, selectedBranch, branchRows, doctorRows, massageSummary, ftSummary, cabinetSummary, massageRows, ftRows, cabinetRows, options) {
  const opts = options || {};
  const includeBaseline = opts.includeBaseline !== false;
  const sheet = getOrCreateSheet_(ss, selectedBranch);
  resetSheetForRender_(sheet);
  let row = 1;
  const fallbackPeriod = computeReportPeriodFromReferenceMoment_(currentDay);
  const startDate = reportPeriod && reportPeriod.startDate
    ? reportPeriod.startDate
    : (fallbackPeriod && fallbackPeriod.startDate) || addDays(currentDay, 1);
  const endDate = reportPeriod && reportPeriod.endDate
    ? reportPeriod.endDate
    : (fallbackPeriod && fallbackPeriod.endDate) || addDays(currentDay, 7);
  const period3dLabel = formatReportPeriodLabel_(startDate, addDays(startDate, 2));
  const period7dLabel = formatReportPeriodLabel_(startDate, endDate);
  sheet.getRange(row, 1, 1, 8)
    .merge()
    .setValue('План загрузки')
    .setFontWeight('bold')
    .setFontSize(13)
    .setBackground('#d9ead3');
  row += 1;
  sheet.getRange(row, 1, 1, 8)
    .merge()
    .setValue(`Филиал: ${selectedBranch}`)
    .setFontWeight('bold')
    .setBackground('#eaf3ff');
  row += 1;
  sheet.getRange(row, 1, 1, 8)
    .merge()
    .setValue(`Сформировано: ${formatDateTimeDDMMYYYY_(new Date())}`)
    .setFontSize(10)
    .setBackground('#f3f8ff');
  row += 2;

  const branchRow = branchRows.length ? branchRows[0] : { branch: selectedBranch, c3: emptyForwardMetric(), c7: emptyForwardMetric(), b3: emptyForwardMetric(), b7: emptyForwardMetric() };
  const physioSummary = mergeCabinetTypeSummary_(cabinetSummary);

  row = renderPlanBlockByHorizon_(sheet, row, '3 дня', period3dLabel, {
    doctorsSummary: { current: branchRow.c3, baseline: branchRow.b3 },
    massageSummary: { current: massageSummary && massageSummary.c3 ? massageSummary.c3 : emptyForwardMetric(), baseline: massageSummary && massageSummary.b3 ? massageSummary.b3 : emptyForwardMetric() },
    ftSummary: { current: ftSummary && ftSummary.c3 ? ftSummary.c3 : emptyForwardMetric(), baseline: ftSummary && ftSummary.b3 ? ftSummary.b3 : emptyForwardMetric() },
    physioSummary: { current: physioSummary.c3, baseline: physioSummary.b3 },
    doctorRows,
    massageRows,
    ftRows,
    cabinetRows,
    horizon: '3d',
    tableBase: 1,
    includeBaseline,
  });

  row += 1;
  row = renderPlanBlockByHorizon_(sheet, row, '7 дней', period7dLabel, {
    doctorsSummary: { current: branchRow.c7, baseline: branchRow.b7 },
    massageSummary: { current: massageSummary && massageSummary.c7 ? massageSummary.c7 : emptyForwardMetric(), baseline: massageSummary && massageSummary.b7 ? massageSummary.b7 : emptyForwardMetric() },
    ftSummary: { current: ftSummary && ftSummary.c7 ? ftSummary.c7 : emptyForwardMetric(), baseline: ftSummary && ftSummary.b7 ? ftSummary.b7 : emptyForwardMetric() },
    physioSummary: { current: physioSummary.c7, baseline: physioSummary.b7 },
    doctorRows,
    massageRows,
    ftRows,
    cabinetRows,
    horizon: '7d',
    tableBase: 5,
    includeBaseline,
  });

  sheet.autoResizeColumns(1, 8);
}

function renderPlanBlockByHorizon_(sheet, row, horizonLabel, periodLabel, ctx) {
  const h = ctx.horizon;
  const includeBaseline = ctx.includeBaseline !== false;
  const summaryHeader = ['Категория', 'Приемные (ч)', 'Занятые (ч)', 'Загрузка (%)', 'Свободные (ч)', 'Заявки (шт)', 'Заявки на ПП (шт)', 'Свободные слоты под ПП'];
  const titleRowRange = sheet.getRange(row, 1, 1, summaryHeader.length);
  const titleRange = sheet.getRange(row, 1, 1, 4);
  const titleTailRange = sheet.getRange(row, 5, 1, summaryHeader.length - 4);
  titleRowRange.breakApart().clearContent();
  titleRange
    .merge()
    .setValue(`Сводный план на ${horizonLabel}. Отчетный период: ${periodLabel}`)
    .setFontWeight('bold')
    .setFontSize(16)
    .setHorizontalAlignment('center')
    .setBackground('#6fa8dc');
  titleTailRange
    .setBackground('#6fa8dc')
    .setBorder(false, false, false, false, false, false);
  row += 1;
  sheet.getRange(row, 1, 1, summaryHeader.length).setValues([summaryHeader]);
  styleForecastHeaderRow(sheet, row, summaryHeader.length);
  row += 1;

  row = renderSummaryCategoryRow_(sheet, row, 'Врачи', ctx.doctorsSummary.current, ctx.doctorsSummary.baseline, h, summaryHeader.length, true, includeBaseline);
  row = renderSummaryCategoryRow_(sheet, row, 'Массажисты', ctx.massageSummary.current, ctx.massageSummary.baseline, h, summaryHeader.length, false, includeBaseline);
  row = renderSummaryCategoryRow_(sheet, row, 'ФТ', ctx.ftSummary.current, ctx.ftSummary.baseline, h, summaryHeader.length, false, includeBaseline);
  row = renderSummaryCategoryRow_(sheet, row, 'Физиотерапия', ctx.physioSummary.current, ctx.physioSummary.baseline, h, summaryHeader.length, false, includeBaseline);

  row += 1;
  row = renderForwardDetailsTable_(sheet, row, `Таблица ${ctx.tableBase} — Врачи (${horizonLabel})`, 'Врач', ctx.doctorRows, h, true, includeBaseline);
  row += 1;
  row = renderForwardDetailsTable_(sheet, row, `Таблица ${ctx.tableBase + 1} — Массажисты (${horizonLabel})`, 'Сотрудник', ctx.massageRows, h, false, includeBaseline);
  row += 1;
  row = renderForwardDetailsTable_(sheet, row, `Таблица ${ctx.tableBase + 2} — ФТ (${horizonLabel})`, 'Сотрудник', ctx.ftRows, h, false, includeBaseline);
  row += 1;
  row = renderCabinetDetailsTable_(sheet, row, `Таблица ${ctx.tableBase + 3} — Кабинеты физиотерапии (${horizonLabel})`, ctx.cabinetRows, h, includeBaseline);

  return row;
}

function renderSummaryCategoryRow_(sheet, row, name, current, baseline, horizon, columns, includePrimaryCols, includeBaseline) {
  const loadCur = current.receptionMin ? (current.occupiedMin / current.receptionMin) * 100 : 0;
  const loadBase = baseline.receptionMin ? (baseline.occupiedMin / baseline.receptionMin) * 100 : 0;
  const values = [
    name,
    round1_(current.receptionMin / 60),
    formatMetricWithOptionalBaseline_(current.occupiedMin / 60, baseline.occupiedMin / 60, includeBaseline),
    formatPercentWithOptionalBaseline_(loadCur, loadBase, includeBaseline),
    round1_(current.freeMin / 60),
    round1_(current.reqCount),
    includePrimaryCols
      ? formatMetricWithOptionalBaseline_(current.primaryCount, baseline.primaryCount, includeBaseline)
      : '',
    includePrimaryCols ? round1_(current.freePP) : '',
  ];
  sheet.getRange(row, 1, 1, columns).setValues([values]);
  styleForecastDataRow(sheet, row, columns);
  styleForecastRow(sheet, row, current, baseline, horizon, 4);
  return row + 1;
}

function renderForwardDetailsTable_(sheet, row, title, firstColTitle, rows, horizon, includePrimaryCols, includeBaseline) {
  const includePrimary = includePrimaryCols !== false;
  const header = [firstColTitle, 'Приемные (ч)', 'Занятые (ч)', 'Загрузка (%)', 'Свободные (ч)', 'Заявки (шт)'];
  if (includePrimary) {
    header.push('Заявки на ПП (шт)', 'Свободные слоты под ПП');
  }
  const columns = header.length;
  sheet.getRange(row, 1, 1, columns).merge().setValue(title).setFontWeight('bold').setBackground('#cfe2f3');
  row += 1;
  sheet.getRange(row, 1, 1, columns).setValues([header]);
  styleForecastHeaderRow(sheet, row, columns);
  row += 1;

  (rows || []).forEach((r) => {
    const current = horizon === '3d' ? r.c3 : r.c7;
    if (!current || !current.receptionMin) return;
    const baseline = horizon === '3d' ? r.b3 : r.b7;
    const loadCur = current.receptionMin ? (current.occupiedMin / current.receptionMin) * 100 : 0;
    const loadBase = baseline.receptionMin ? (baseline.occupiedMin / baseline.receptionMin) * 100 : 0;
    const values = [
      str_(r.doctor),
      round1_(current.receptionMin / 60),
      formatMetricWithOptionalBaseline_(current.occupiedMin / 60, baseline.occupiedMin / 60, includeBaseline),
      formatPercentWithOptionalBaseline_(loadCur, loadBase, includeBaseline),
      round1_(current.freeMin / 60),
      round1_(current.reqCount),
    ];
    if (includePrimary) {
      values.push(
        formatMetricWithOptionalBaseline_(current.primaryCount, baseline.primaryCount, includeBaseline),
        round1_(current.freePP)
      );
    }
    sheet.getRange(row, 1, 1, columns).setValues([values]);
    styleForecastDataRow(sheet, row, columns);
    styleForecastRow(sheet, row, current, baseline, horizon, 4);
    row += 1;
  });

  return row;
}

function renderCabinetDetailsTable_(sheet, row, title, rows, horizon, includeBaseline) {
  const columns = 6;
  const header = ['Кабинет', 'Приемные (ч)', 'Занятые (ч)', 'Загрузка (%)', 'Свободные (ч)', 'Заявки (шт)'];
  sheet.getRange(row, 1, 1, columns).merge().setValue(title).setFontWeight('bold').setBackground('#cfe2f3');
  row += 1;
  sheet.getRange(row, 1, 1, columns).setValues([header]);
  styleForecastHeaderRow(sheet, row, columns);
  row += 1;

  (rows || []).forEach((r) => {
    const current = horizon === '3d' ? r.c3 : r.c7;
    if (!current || !current.receptionMin) return;
    const baseline = horizon === '3d' ? r.b3 : r.b7;
    const loadCur = current.receptionMin ? (current.occupiedMin / current.receptionMin) * 100 : 0;
    const loadBase = baseline.receptionMin ? (baseline.occupiedMin / baseline.receptionMin) * 100 : 0;
    const values = [
      str_(r.cabinet),
      round1_(current.receptionMin / 60),
      formatMetricWithOptionalBaseline_(current.occupiedMin / 60, baseline.occupiedMin / 60, includeBaseline),
      formatPercentWithOptionalBaseline_(loadCur, loadBase, includeBaseline),
      round1_(current.freeMin / 60),
      round1_(current.reqCount),
    ];
    sheet.getRange(row, 1, 1, columns).setValues([values]);
    styleForecastDataRow(sheet, row, columns);
    styleForecastRow(sheet, row, current, baseline, horizon, 4);
    row += 1;
  });

  return row;
}

function formatMetricWithOptionalBaseline_(currentValue, baselineValue, includeBaseline) {
  const current = round1_(Number(currentValue) || 0);
  const baseline = round1_(Number(baselineValue) || 0);
  return includeBaseline ? `${current} (${baseline})` : `${current}`;
}

function formatPercentWithOptionalBaseline_(currentValue, baselineValue, includeBaseline) {
  const current = round0(Number(currentValue) || 0);
  const baseline = round0(Number(baselineValue) || 0);
  return includeBaseline ? `${current} (${baseline})` : `${current}`;
}

function styleForecastHeaderRow(sheet, row, columns) {
  sheet.getRange(row, 1, 1, columns)
    .setFontWeight('bold')
    .setBackground('#f3f3f3')
    .setBorder(true, true, true, true, true, true);
}
function styleForecastDataRow(sheet, row, columns) {
  const range = sheet.getRange(row, 1, 1, columns);
  range.setBorder(true, true, true, true, true, true);
  sheet.getRange(row, 1).setBackground('#fafafa');
}
function styleForecastRow(sheet, row, current, baseline, horizon, loadColumn) {
  const loadCur = current.receptionMin ? (current.occupiedMin / current.receptionMin) * 100 : 0;
  const targetCol = loadColumn || 5;
  sheet.getRange(row, targetCol).setBackground(forecastLoadColorByHorizon(loadCur, horizon));
}
function forecastLoadColorByHorizon(loadPercent, horizon) {
  if (horizon === '7d') {
    if (loadPercent < 20) return '#ff0000';
    if (loadPercent < 35) return '#fff2cc';
    if (loadPercent > 60) return '#f4cccc';
    if (loadPercent > 50) return '#d9ead3';
    return '#ffffff';
  }
  if (loadPercent < 25) return '#ff0000';
  if (loadPercent < 40) return '#fff2cc';
  if (loadPercent > 75) return '#f4cccc';
  if (loadPercent > 60) return '#d9ead3';
  return '#ffffff';
}
function sendForwardReportEmail(ss, selectedBranch, currentDay) {
  const sheet = ss.getSheetByName(selectedBranch);
  const mailingSheet = ss.getSheetByName(FL2_SHEET_MAILING);
  if (!sheet || !mailingSheet) {
    throw new Error('Не найден лист отчета филиала или лист Отправка');
  }
  const mailingRows = getSheetObjects_(mailingSheet);
  const target = mailingRows.find((r) => str_(r['Филиал']) === selectedBranch);
  if (!target) throw new Error(`Для филиала "${selectedBranch}" нет строки в листе Отправка`);
  const to = parseEmailList(target['Кому']);
  const cc = parseEmailList(target['Копия']);
  if (!to.length) throw new Error(`Для филиала "${selectedBranch}" не заполнено поле Кому`);
  const prep = prepareForwardLoadInput_(ss, { selectedBranch, persistUnassigned: false, currentDay });
  const fallbackPeriod = computeReportPeriodFromReferenceMoment_(currentDay);
  const startDate = prep.reportPeriod && prep.reportPeriod.startDate
    ? prep.reportPeriod.startDate
    : (fallbackPeriod && fallbackPeriod.startDate) || addDays(currentDay, 1);
  const reportStartLabel = formatDateDDMMYYYY_(startDate);
  const subject = `План загрузки. ${selectedBranch}. ${reportStartLabel}`;
  const body = [
    sheetToHtmlTable(sheet),
    '<p><b>Цветовая интерпретация загрузки:</b> для горизонта 3 дня: <span style="background:#ff0000;padding:2px 6px;">красный</span> &lt; 25%, <span style="background:#fff2cc;padding:2px 6px;">желтый</span> 25–40%, белый 40–60%, <span style="background:#d9ead3;padding:2px 6px;">зеленый</span> 60–75%, <span style="background:#f4cccc;padding:2px 6px;">бледно-розовый</span> > 75%. Для горизонта 7 дней: <span style="background:#ff0000;padding:2px 6px;">красный</span> &lt; 20%, <span style="background:#fff2cc;padding:2px 6px;">желтый</span> 20–35%, белый 35–50%, <span style="background:#d9ead3;padding:2px 6px;">зеленый</span> 50–60%, <span style="background:#f4cccc;padding:2px 6px;">бледно-розовый</span> > 60%.</p>',
    '<p><b>Пояснение:</b> значения в скобках — это обычный уровень (среднее за последние 6 недель по тому же дню недели).</p>',
    '<p><b>Пояснение:</b> Приемные (ч) — часы из графика врача; Занятые (ч) — часы занятых заявками; Загрузка (%) = Занятые/Приемные; Свободные (ч) = Приемные − Занятые; Свободные ПП — количество свободных часовых слотов под первичный прием.</p>',
    buildMailingServiceInfoHtml_(ss, selectedBranch, to, cc, sheet),
  ].join('');
  MailApp.sendEmail({
    to: to.join(','),
    cc: cc.join(','),
    subject,
    htmlBody: body,
  });
}

function processSourceDataFromDriveTriggerAggregatorsPrepareData() {
  processSourceDataFromDrive({ interactive: false });
  updateDiscountsByPlan({ silent: true });
  sendDiscountsEmailsByMode_({
    targetMode: 'aggregators',
    silent: true,
  });
}

function processSourceDataFromDriveTriggerBranchesOverallAndDiscounts() {
  processSourceDataFromDrive({ interactive: false });

  runForwardLoadReportsDirect_({
    includeBaseline: true,
    sendEmails: true,
  });

  buildOverallForecastCore_({
    sendEmail: true,
    refreshDiscountsAfter: false,
  });

  updateDiscountsByPlan({ silent: true });
  sendDiscountsEmails({ silent: true });
}

function doGet(e) {
  const action = str_(e && e.parameter && e.parameter.action).trim();
  if (!action) {
    return ContentService.createTextOutput('OK');
  }

  if (action === 'aggregators_prepare_data') {
    processSourceDataFromDriveTriggerAggregatorsPrepareData();
    return ContentService.createTextOutput('DONE: aggregators_prepare_data');
  }

  if (action === 'branches_overall_and_discounts') {
    processSourceDataFromDriveTriggerBranchesOverallAndDiscounts();
    return ContentService.createTextOutput('DONE: branches_overall_and_discounts');
  }

  return ContentService.createTextOutput(`UNKNOWN_ACTION: ${action}`);
}

function buildOverallForecastCore_(options) {
  const opts = options || {};
  const refreshDiscountsAfter = opts.refreshDiscountsAfter === true;
  const ss = SpreadsheetApp.getActive();
  ensureDoctorScheduleFresh(ss);
  const sheets = ss.getSheets();
  const clinicRows = [];
  let reportDate = '';
  let reportPeriodLabel = '';
  sheets.forEach((sheet) => {
    const data = sheet.getDataRange().getDisplayValues();
    if (!data.length) return;
    if (!isBranchPlanSheetData_(data)) return;
    const parsed = parseClinicForecastSheet(data);
    if (!parsed) return;
    if (!reportDate && parsed.reportDate) reportDate = parsed.reportDate;
    if (!reportPeriodLabel && parsed.reportPeriodLabel) reportPeriodLabel = parsed.reportPeriodLabel;
    clinicRows.push(...parsed.rows);
  });
  if (!clinicRows.length) {
    throw new Error('Не найдены листы филиалов с планом для сборки общего отчета');
  }
  const effectivePeriodLabel = reportPeriodLabel || formatReportPeriodLabel_(new Date(), addDays(new Date(), 6));
  renderOverallForecastSheet(ss, effectivePeriodLabel, clinicRows);
  if (opts.sendEmail) {
    sendOverallForecastEmail(ss, effectivePeriodLabel);
  }
  if (refreshDiscountsAfter) {
    refreshDiscountsAfterPlanUpdate_();
  }
  return effectivePeriodLabel;
}

function buildOverallForecastReport() {
  const ui = SpreadsheetApp.getUi();
  const reportPeriodLabel = buildOverallForecastCore_({ sendEmail: false });
  const sendAnswer = ui.alert('Общий план', 'Сделать рассылку общего плана?', ui.ButtonSet.YES_NO);
  if (sendAnswer === ui.Button.YES) {
    sendOverallForecastEmail(SpreadsheetApp.getActive(), reportPeriodLabel);
  }
  SpreadsheetApp.getActive().toast('Общий план собран', MENU_NAME, 5);
}

function updateDiscountsByPlan(options) {
  const opts = options || {};
  const silent = Boolean(opts.silent);
  const ss = SpreadsheetApp.getActive();
  const discountsSheet = ss.getSheetByName(SHEET_DISCOUNTS);
  if (!discountsSheet) {
    throw new Error('Не найден лист "Скидки"');
  }

  const data = discountsSheet.getDataRange().getDisplayValues();
  if (data.length < 2) {
    if (!silent) SpreadsheetApp.getActive().toast('Лист "Скидки" пустой', MENU_NAME, 5);
    return;
  }

  const headers = data[0].map((h) => str_(h));
  const col = buildHeaderIndexMap_(headers);
  const required = [
    'Врачи',
    'Мин окон ПП 3',
    'Мин окон ПП 7',
    'Бесплатный ПП с МРТ',
    'Условие Бесплатный с ПП МРТ',
  ];
  required.forEach((name) => {
    if (col[name] === undefined) throw new Error(`На листе "Скидки" не найдена колонка "${name}"`);
  });

  const outputColsPP = findHeaderIndexes_(col, ['Стоимость ПП', 'Скидка ПП']);
  const outputColsOnline = findHeaderIndexes_(col, ['Стоимость Онлайн ПП', 'Скидка Онлайн']);
  const outputColsP = findHeaderIndexes_(col, ['Стоимость П', 'Скидка П']);
  const outputColsAggregators = findHeaderIndexes_(col, ['Стоимость Агрегаторы', 'Скидка Агрегаторы']);
  [
    ['Стоимость ПП', outputColsPP],
    ['Стоимость Онлайн ПП', outputColsOnline],
    ['Стоимость П', outputColsP],
    ['Стоимость Агрегаторы', outputColsAggregators],
  ].forEach(([name, indexes]) => {
    if (!indexes.length) throw new Error(`На листе "Скидки" не найдена колонка "${name}"`);
  });

  const doctorMetrics = collectDoctorPlanMetricsByName_(ss);

  const updates = [];
  for (let i = 1; i < data.length; i += 1) {
    const row = data[i].slice();
    const doctor = str_(row[col['Врачи']]);
    if (!doctor) {
      updates.push(['', '', '', '', '']);
      continue;
    }

    const m = doctorMetrics.get(doctor) || { load3: null, load7: null, freePP3: 0, freePP7: 0 };
    const minPP3 = parseLocaleNumber(row[col['Мин окон ПП 3']]);
    const minPP7 = parseLocaleNumber(row[col['Мин окон ПП 7']]);

    const cond = {
      '3-25': m.load3 !== null && m.load3 < 25 && m.freePP3 >= minPP3,
      '3-40': m.load3 !== null && m.load3 < 40 && m.freePP3 >= minPP3,
      '7-20': m.load7 !== null && m.load7 < 20 && m.freePP7 >= minPP7,
      '7-35': m.load7 !== null && m.load7 < 35 && m.freePP7 >= minPP7,
    };

    const discountPP = pickMinimumDiscountByConditions_(row, col, {
      '3-25': ['Стоимость ПП 3-25', 'Скидка ПП 3-25'],
      '3-40': ['Стоимость ПП 3-40', 'Скидка ПП 3-40'],
      '7-20': ['Стоимость ПП 7-20', 'Скидка ПП 7-20'],
      '7-35': ['Стоимость  ПП 7-35', 'Стоимость ПП 7-35', 'Скидка  ПП 7-35', 'Скидка ПП 7-35'],
    }, cond);

    const discountOnline = pickMinimumDiscountByConditions_(row, col, {
      '3-25': ['Стоимость Онлайн 3-25', 'Стоимость Онлайн ПП 3-25', 'Скидка Онлайн 3-25'],
      '3-40': ['Стоимость Онлайн 3-40', 'Стоимость Онлайн ПП 3-40', 'Скидка Онлайн 3-40'],
    }, cond);

    const discountP = pickMinimumDiscountByConditions_(row, col, {
      '3-25': ['Стоимость П 3-25', 'Скидка П 3-25'],
      '3-40': ['Стоимость П 3-40', 'Скидка П 3-40'],
      '7-20': ['Стоимость П 7-20', 'Скидка П 7-20'],
      '7-35': ['Стоимость  П 7-35', 'Стоимость П 7-35', 'Скидка  П 7-35', 'Скидка П 7-35'],
    }, cond);

    const discountAggregators = pickMinimumDiscountByConditions_(row, col, {
      '7-20': ['Стоимость Агрегаторы 7-20', 'Скидка Агрегаторы 7-20'],
    }, cond);

    const mriCondition = str_(row[col['Условие Бесплатный с ПП МРТ']]);
    const isMriFree = isMriConditionSatisfied_(mriCondition, cond);

    updates.push([
      discountPP,
      discountOnline,
      discountP,
      discountAggregators,
      isMriFree ? 'Да' : '',
    ]);
  }

  const outputColumns = [
    ...outputColsPP.map((idx) => idx + 1),
    ...outputColsOnline.map((idx) => idx + 1),
    ...outputColsP.map((idx) => idx + 1),
    ...outputColsAggregators.map((idx) => idx + 1),
    col['Бесплатный ПП с МРТ'] + 1,
  ];
  const expandedUpdates = updates.map((row) => {
    const values = [];
    outputColsPP.forEach(() => values.push(row[0]));
    outputColsOnline.forEach(() => values.push(row[1]));
    outputColsP.forEach(() => values.push(row[2]));
    outputColsAggregators.forEach(() => values.push(row[3]));
    values.push(row[4]);
    return values;
  });
  writeColumnBatch_(discountsSheet, 2, outputColumns, expandedUpdates);

  if (!silent) SpreadsheetApp.getActive().toast('Скидки обновлены по данным плана', MENU_NAME, 5);
}

function collectDoctorPlanMetricsByName_(ss) {
  const byDoctor = new Map();
  ss.getSheets().forEach((sheet) => {
    const data = sheet.getDataRange().getDisplayValues();
    if (!isBranchPlanSheetData_(data)) return;

    const detailRows = parsePlanDetailRowsForArchive_(data).filter((r) => r.category === 'doctor' && !r.isTotal);
    detailRows.forEach((r) => {
      const doctor = str_(r.objectName);
      if (!doctor) return;
      if (!byDoctor.has(doctor)) byDoctor.set(doctor, { load3: null, load7: null, freePP3: 0, freePP7: 0 });
      const entry = byDoctor.get(doctor);
      if (r.horizon === '3 дня') {
        entry.load3 = r.loadCur;
        entry.freePP3 = r.freePP;
      } else if (r.horizon === '7 дней') {
        entry.load7 = r.loadCur;
        entry.freePP7 = r.freePP;
      }
    });
  });
  return byDoctor;
}

function buildHeaderIndexMap_(headers) {
  const map = {};
  (headers || []).forEach((h, i) => {
    map[str_(h)] = i;
  });
  return map;
}

function findFirstHeaderIndex_(colMap, names) {
  const indexes = findHeaderIndexes_(colMap, names);
  return indexes.length ? indexes[0] : undefined;
}

function findHeaderIndexes_(colMap, names) {
  const candidates = Array.isArray(names) ? names : [names];
  const seen = new Set();
  const indexes = [];
  for (let i = 0; i < candidates.length; i += 1) {
    const name = candidates[i];
    const idx = colMap[name];
    if (idx === undefined || seen.has(idx)) continue;
    seen.add(idx);
    indexes.push(idx);
  }
  return indexes;
}

function normalizeDiscountMailRow_(row) {
  const item = Object.assign({}, row || {});
  if (item['Скидка ПП'] === undefined && item['Стоимость ПП'] !== undefined) item['Скидка ПП'] = item['Стоимость ПП'];
  if (item['Скидка Онлайн'] === undefined && item['Стоимость Онлайн ПП'] !== undefined) item['Скидка Онлайн'] = item['Стоимость Онлайн ПП'];
  if (item['Скидка П'] === undefined && item['Стоимость П'] !== undefined) item['Скидка П'] = item['Стоимость П'];
  if (item['Скидка Агрегаторы'] === undefined && item['Стоимость Агрегаторы'] !== undefined) item['Скидка Агрегаторы'] = item['Стоимость Агрегаторы'];
  return item;
}

function getDiscountEmailColumnTitle_(column) {
  if (column === 'Скидка ПП') return 'ПП';
  if (column === 'Скидка Онлайн') return 'Онлайн ПП';
  if (column === 'Скидка П') return 'П';
  return column;
}

function pickMinimumDiscountByConditions_(row, colMap, ruleColumns, condMap) {
  const candidates = [];
  Object.keys(ruleColumns || {}).forEach((rule) => {
    if (!condMap[rule]) return;
    const columnNames = Array.isArray(ruleColumns[rule]) ? ruleColumns[rule] : [ruleColumns[rule]];
    const idx = findFirstHeaderIndex_(colMap, columnNames);
    if (idx === undefined) return;
    const value = str_(row[idx]);
    if (!value) return;
    const parsed = parseDiscountSortableValue_(value);
    candidates.push({ value, parsed });
  });
  if (!candidates.length) return '';

  const hasNumeric = candidates.some((c) => c.parsed !== null);
  if (!hasNumeric) return candidates[0].value;

  candidates.sort((a, b) => {
    const av = a.parsed === null ? Number.POSITIVE_INFINITY : a.parsed;
    const bv = b.parsed === null ? Number.POSITIVE_INFINITY : b.parsed;
    return av - bv;
  });
  return candidates[0].value;
}

function parseDiscountSortableValue_(value) {
  const m = str_(value).replace(',', '.').match(/-?\d+(?:\.\d+)?/);
  if (!m) return null;
  const n = Number(m[0]);
  return Number.isFinite(n) ? n : null;
}

function isMriConditionSatisfied_(condition, cond) {
  const c = str_(condition);
  if (!c) return false;
  if (c === '7-20') return Boolean(cond['7-20']);
  if (c === '7-35') return Boolean(cond['7-35'] || cond['7-20']);
  if (c === '3-25') return Boolean(cond['3-25']);
  if (c === '3-40') return Boolean(cond['3-40'] || cond['3-25']);
  return false;
}

function writeColumnBatch_(sheet, startRow, columns, rows) {
  (columns || []).forEach((colNum, idx) => {
    const values = (rows || []).map((r) => [r[idx] === undefined ? '' : r[idx]]);
    if (!values.length) return;
    sheet.getRange(startRow, colNum, values.length, 1).setValues(values);
  });
}

function sendDiscountsEmailsByMode_(options) {
  const opts = options || {};
  const targetMode = str_(opts.targetMode);
  const silent = Boolean(opts.silent);
  const ss = SpreadsheetApp.getActive();
  const discountsSheet = ss.getSheetByName(SHEET_DISCOUNTS);
  const mailingSheet = ss.getSheetByName(FL2_SHEET_MAILING);
  if (!discountsSheet || !mailingSheet) {
    throw new Error('Не найдены листы "Скидки" или "Отправка"');
  }

  const discountRows = getSheetObjects_(discountsSheet).map((row) => normalizeDiscountMailRow_(row));
  const mailingRows = getSheetObjects_(mailingSheet);

  let mailingBranchName = 'Скидки';
  let allowedSectionKeys = ['pp_discount', 'p_discount', 'smm', 'site', 'aggregators'];
  let subject = `Сводка по скидкам на ${formatDateDDMMYYYY_(new Date())}`;

  if (targetMode === 'aggregators') {
    mailingBranchName = 'Агрегаторы';
    allowedSectionKeys = ['aggregators'];
    subject = `Скидки для агрегаторов на ${formatDateDDMMYYYY_(new Date())}`;
  } else if (targetMode === 'non_aggregators') {
    mailingBranchName = 'Скидки';
    allowedSectionKeys = ['pp_discount', 'p_discount', 'smm', 'site', 'aggregators'];
    subject = `Сводка по скидкам на ${formatDateDDMMYYYY_(new Date())}`;
  } else {
    throw new Error(`Неизвестный режим отправки скидок: ${targetMode}`);
  }

  const mailingTarget = mailingRows.find((r) => str_(r['Филиал']) === mailingBranchName);
  if (!mailingTarget) {
    throw new Error(`В листе "Отправка" не найдена строка "${mailingBranchName}"`);
  }

  const to = parseEmailList(mailingTarget['Кому']);
  const cc = parseEmailList(mailingTarget['Копия']);
  if (!to.length) {
    if (!silent) SpreadsheetApp.getActive().toast(`Для рассылки "${mailingBranchName}" не заполнено поле "Кому"`, MENU_NAME, 5);
    return;
  }

  const doctorRows = discountRows.filter((r) => str_(r['Врачи']));
  const ppAndOnlineRows = doctorRows.filter((r) => hasNonZeroDiscountValue_(r['Скидка ПП']) || hasNonZeroDiscountValue_(r['Скидка Онлайн']) || isTruthyCell_(r['Бесплатный ПП с МРТ']));
  const aggregatorsRows = doctorRows.filter((r) => hasNonZeroDiscountValue_(r['Скидка Агрегаторы']));
  const pRows = doctorRows.filter((r) => hasNonZeroDiscountValue_(r['Скидка П']));
  const smmRows = doctorRows.filter((r) => isTruthyCell_(r['SMM'])
    && (hasNonZeroDiscountValue_(r['Скидка ПП']) || isTruthyCell_(r['Бесплатный ПП с МРТ'])));
  const siteRows = doctorRows.filter((r) => isTruthyCell_(r['Сайт'])
    && (hasNonZeroDiscountValue_(r['Скидка ПП']) || isTruthyCell_(r['Бесплатный ПП с МРТ'])));

  const sections = [
    {
      key: 'pp_discount',
      title: 'Скидки на ПП и Онлайн',
      rows: ppAndOnlineRows,
      columns: ['Врачи', 'Скидка ПП', 'Скидка Онлайн', 'Бесплатный ПП с МРТ'],
    },
    {
      key: 'aggregators',
      title: 'Скидки для агрегаторов',
      rows: aggregatorsRows,
      columns: ['Врачи', 'Скидка Агрегаторы'],
    },
    {
      key: 'p_discount',
      title: 'Скидки на П',
      rows: pRows,
      columns: ['Врачи', 'Скидка П'],
    },
    {
      key: 'smm',
      title: 'Скидки для SMM',
      rows: smmRows,
      columns: ['Врачи', 'Скидка ПП', 'Бесплатный ПП с МРТ'],
    },
    {
      key: 'site',
      title: 'Скидки для Сайта',
      rows: siteRows,
      columns: ['Врачи', 'Скидка ПП', 'Бесплатный ПП с МРТ'],
    },
  ];

  const currentState = buildDiscountSectionsState_(sections);
  const previousState = readDiscountsEmailState_(ss);
  const changeDiff = diffDiscountDoctorsBySection_(previousState, currentState);

  const sectionsForSend = sections
    .filter((section) => sectionHasDiscountDiff_(section, changeDiff))
    .filter((section) => allowedSectionKeys.includes(section.key));
  if (!sectionsForSend.length) {
    if (!silent) SpreadsheetApp.getActive().toast('Нет данных для отправки скидок', MENU_NAME, 5);
    return;
  }

  const htmlBody = buildDiscountsDigestHtmlBody_(sectionsForSend, changeDiff, previousState, currentState);
  MailApp.sendEmail({
    to: to.join(','),
    cc: cc.join(','),
    subject,
    htmlBody,
  });

  saveDiscountsEmailState_(ss, currentState);

  if (!silent) {
    SpreadsheetApp.getActive().toast('Рассылка скидок отправлена: 1', MENU_NAME, 5);
  }
}

function sendDiscountsEmails(options) {
  return sendDiscountsEmailsByMode_({
    targetMode: 'non_aggregators',
    silent: options && options.silent,
  });
}

function buildDiscountsDigestHtmlBody_(sections, changeDiff, previousState, currentState) {
  const generatedAtMoscow = formatDateTimeMoscow_(new Date());
  const blocks = (sections || []).map((section) => {
    const title = `<h3 style="font-family:Arial,sans-serif;margin:20px 0 8px;">${section.title}</h3>`;
    const table = buildDiscountsHtmlBody_(section, changeDiff, previousState, currentState);
    return `${title}${table}`;
  });

  return [
    '<div style="font-family:Arial,sans-serif;font-size:13px;line-height:1.4;">',
    `<p>Дата и московское время формирования информации: ${generatedAtMoscow}</p>`,
    ...blocks,
    '</div>',
  ].filter((part) => str_(part)).join('');
}

function formatDateTimeMoscow_(value) {
  const date = value instanceof Date ? value : toDate_(value);
  if (!date) return '';
  return Utilities.formatDate(date, 'Europe/Moscow', 'dd.MM.yyyy HH:mm:ss');
}

function sectionHasDiscountDiff_(section, changeDiff) {
  const key = section && section.key;
  if (!key || !changeDiff) return false;
  const d = changeDiff[key] || {};
  return (Array.isArray(d.added) && d.added.length)
    || (Array.isArray(d.changed) && d.changed.length)
    || (Array.isArray(d.unchanged) && d.unchanged.length)
    || (Array.isArray(d.removed) && d.removed.length);
}

function buildDiscountSectionsState_(sections) {
  const out = {};
  (sections || []).forEach((section) => {
    const key = str_(section && section.key);
    if (!key) return;
    out[key] = buildDiscountSectionState_((section && section.rows) || [], (section && section.columns) || []);
  });
  return out;
}

function buildDiscountSectionState_(rows, columns) {
  const out = new Map();
  (rows || []).forEach((row) => {
    const doctor = str_(row && row['Врачи']);
    if (!doctor) return;
    const payload = {};
    (columns || []).forEach((column) => {
      if (column === 'Врачи') return;
      payload[column] = str_(row[column]);
    });
    out.set(doctor, payload);
  });
  return out;
}

function diffDiscountDoctorsBySection_(previousState, currentState) {
  const sectionKeys = Array.from(new Set([
    ...Object.keys(previousState || {}),
    ...Object.keys(currentState || {}),
  ]));
  const diff = {};
  sectionKeys.forEach((key) => {
    const prevMap = previousState && previousState[key] instanceof Map ? previousState[key] : new Map();
    const curMap = currentState && currentState[key] instanceof Map ? currentState[key] : new Map();
    const doctors = Array.from(new Set([...curMap.keys(), ...prevMap.keys()]));
    const byDoctor = {};
    const added = [];
    const changed = [];
    const unchanged = [];
    const removed = [];

    doctors.forEach((doctor) => {
      const hasPrev = prevMap.has(doctor);
      const hasCur = curMap.has(doctor);
      const prevPayload = hasPrev ? (prevMap.get(doctor) || {}) : {};
      const curPayload = hasCur ? (curMap.get(doctor) || {}) : {};

      if (hasCur && !hasPrev) {
        byDoctor[doctor] = { status: 'added', changedColumns: [] };
        added.push(doctor);
        return;
      }
      if (!hasCur && hasPrev) {
        byDoctor[doctor] = { status: 'removed', changedColumns: [] };
        removed.push(doctor);
        return;
      }

      const changedColumns = [];
      const columns = Array.from(new Set([...Object.keys(prevPayload), ...Object.keys(curPayload)]));
      columns.forEach((column) => {
        if (str_(prevPayload[column]) !== str_(curPayload[column])) {
          changedColumns.push(column);
        }
      });

      if (changedColumns.length) {
        byDoctor[doctor] = { status: 'changed', changedColumns };
        changed.push(doctor);
      } else {
        byDoctor[doctor] = { status: 'unchanged', changedColumns: [] };
        unchanged.push(doctor);
      }
    });

    const sortRu = (a, b) => a.localeCompare(b, 'ru');
    diff[key] = {
      byDoctor,
      added: added.sort(sortRu),
      changed: changed.sort(sortRu),
      unchanged: unchanged.sort(sortRu),
      removed: removed.sort(sortRu),
    };
  });
  return diff;
}

function readDiscountsEmailState_(ss) {
  const sheet = getOrCreateSheet_(ss, FL2_SHEET_DISCOUNTS_EMAIL_STATE);
  const values = sheet.getDataRange().getValues();
  if (!values.length) {
    sheet.getRange(1, 1, 1, 4).setValues([['Блок', 'Врач', 'Данные', 'Обновлено']]);
    return {};
  }

  const header = values[0].map((h) => str_(h));
  const idxSection = header.indexOf('Блок') >= 0 ? header.indexOf('Блок') : header.indexOf('Канал');
  const idxDoctor = header.indexOf('Врач');
  const idxPayload = header.indexOf('Данные');
  if (idxSection < 0 || idxDoctor < 0 || idxPayload < 0) {
    sheet.clearContents();
    sheet.getRange(1, 1, 1, 4).setValues([['Блок', 'Врач', 'Данные', 'Обновлено']]);
    return {};
  }

  const out = {};
  for (let i = 1; i < values.length; i += 1) {
    const row = values[i];
    const sectionKey = str_(row[idxSection]);
    const doctor = str_(row[idxDoctor]);
    const payloadRaw = str_(row[idxPayload]);
    if (!sectionKey || !doctor) continue;
    if (!(out[sectionKey] instanceof Map)) out[sectionKey] = new Map();

    let payload = {};
    try {
      payload = payloadRaw ? JSON.parse(payloadRaw) : {};
    } catch (e) {
      payload = {};
    }
    out[sectionKey].set(doctor, payload);
  }
  return out;
}

function saveDiscountsEmailState_(ss, state) {
  const sheet = getOrCreateSheet_(ss, FL2_SHEET_DISCOUNTS_EMAIL_STATE);
  sheet.clearContents();
  const header = ['Блок', 'Врач', 'Данные', 'Обновлено'];
  sheet.getRange(1, 1, 1, header.length).setValues([header]);

  const now = new Date();
  const sectionKeys = Object.keys(state || {}).sort((a, b) => a.localeCompare(b, 'ru'));
  const rows = [];
  sectionKeys.forEach((key) => {
    const doctorsMap = state[key] instanceof Map ? state[key] : new Map();
    const doctors = [...doctorsMap.keys()].sort((a, b) => a.localeCompare(b, 'ru'));
    doctors.forEach((doctor) => {
      rows.push([key, doctor, JSON.stringify(doctorsMap.get(doctor) || {}), now]);
    });
  });

  if (rows.length) {
    sheet.getRange(2, 1, rows.length, header.length).setValues(rows);
  }
}

function hasNonZeroDiscountValue_(value) {
  const text = str_(value);
  if (!text) return false;
  if (text === '0' || text === '0.0' || text === '0,0' || text === '0%') return false;
  const num = parseDiscountSortableValue_(text);
  if (num === null) return true;
  return num !== 0;
}

function isTruthyCell_(value) {
  const text = str_(value).toLowerCase();
  return text === 'true' || text === 'истина' || text === 'да' || text === '1' || text === '✓' || text === '✔';
}

function buildDiscountsHtmlBody_(section, changeDiff, previousState, currentState) {
  const intro = section && section.intro;
  const columns = section && section.columns;
  const key = section && section.key;
  const prevMap = key && previousState && previousState[key] instanceof Map ? previousState[key] : new Map();
  const curMap = key && currentState && currentState[key] instanceof Map ? currentState[key] : new Map();
  const sectionDiff = key && changeDiff ? (changeDiff[key] || {}) : {};

  const sortedDoctors = []
    .concat(sectionDiff.added || [])
    .concat(sectionDiff.changed || [])
    .concat(sectionDiff.unchanged || [])
    .concat(sectionDiff.removed || []);

  const header = (columns || []).map((c) => `<th style="border:1px solid #cfd8dc;padding:6px 8px;background:#f3f3f3;">${escapeHtml_(getDiscountEmailColumnTitle_(c))}</th>`).join('');
  const bodyRows = sortedDoctors.map((doctor) => {
    const doctorDiff = sectionDiff.byDoctor && sectionDiff.byDoctor[doctor] ? sectionDiff.byDoctor[doctor] : { status: 'unchanged', changedColumns: [] };
    const status = doctorDiff.status;
    const changedColumns = doctorDiff.changedColumns || [];
    const prevPayload = prevMap.get(doctor) || {};
    const curPayload = curMap.get(doctor) || {};

    const cells = (columns || []).map((column) => {
      const currentValue = column === 'Врачи' ? doctor : str_(curPayload[column]);
      const previousValue = column === 'Врачи' ? doctor : str_(prevPayload[column]);
      const cell = formatDiscountCellValue_(column, currentValue, previousValue, status, changedColumns);
      return `<td style="border:1px solid #cfd8dc;padding:6px 8px;">${cell}</td>`;
    }).join('');
    return `<tr>${cells}</tr>`;
  }).join('');
  return [
    intro ? `<p>${escapeHtml_(intro)}</p>` : '',
    '<table style="border-collapse:collapse;font-family:Arial,sans-serif;font-size:13px;line-height:1.35;">',
    `<tr>${header}</tr>`,
    bodyRows,
    '</table>',
  ].filter((part) => str_(part)).join('');
}

function formatDiscountCellValue_(column, currentValue, previousValue, status, changedColumns) {
  const current = str_(currentValue);
  const previous = str_(previousValue);
  const isChangedColumn = (changedColumns || []).indexOf(column) >= 0;

  if (status === 'removed') {
    return `<span style="color:#b71c1c;text-decoration:line-through;">${escapeHtml_(previous || current)}</span>`;
  }
  if (status === 'added') {
    return `<span style="color:#1b5e20;font-weight:700;">${escapeHtml_(current)}</span>`;
  }
  if (status === 'changed' && column !== 'Врачи' && isChangedColumn) {
    if (!previous && current) {
      return `<span style="color:#1b5e20;font-weight:700;">${escapeHtml_(current)}</span>`;
    }
    if (previous && !current) {
      return [
        '<span style="color:#1b5e20;font-weight:700;">—</span>',
        ' ',
        `<span style="color:#b71c1c;text-decoration:line-through;">${escapeHtml_(previous)}</span>`,
      ].join('');
    }
    return [
      `<span style="color:#1b5e20;font-weight:700;">${escapeHtml_(current)}</span>`,
      ' ',
      `<span style="color:#b71c1c;text-decoration:line-through;">${escapeHtml_(previous)}</span>`,
    ].join('');
  }

  return escapeHtml_(current || previous);
}

function escapeHtml_(value) {
  return str_(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function isBranchPlanSheetData_(data) {
  if (!data || !data.length) return false;
  const firstCol = data.map((r) => str_(r && r[0]));
  const hasPlanHeader = firstCol.some((v) => v === 'План загрузки' || v.startsWith('План загрузки. Отчетный период:'));
  const hasBranchHeader = firstCol.some((v) => v.startsWith('Филиал:'));
  return hasPlanHeader && hasBranchHeader;
}

function parseClinicForecastSheet(data) {
  const firstCol = (data || []).map((r) => str_(r && r[0]));
  const legacyPlanHeader = firstCol.find((v) => v.startsWith('План загрузки. Отчетный период:')) || '';
  const plan7dHeader = firstCol.find((v) => v.startsWith('Сводный план на 7 дней. Отчетный период:')) || '';
  const plan3dHeader = firstCol.find((v) => v.startsWith('Сводный план на 3 дня. Отчетный период:')) || '';
  const periodSource = plan7dHeader || legacyPlanHeader || plan3dHeader;
  const dateMatch = periodSource.match(/(\d{2}\.\d{2}\.\d{4})/);
  const reportDate = dateMatch ? dateMatch[1] : '';
  const reportPeriodLabel = periodSource
    .replace(/^План загрузки\. Отчетный период:\s*/i, '')
    .replace(/^Сводный план на (3 дня|7 дней)\. Отчетный период:\s*/i, '')
    .trim();
  const branchLine = firstCol.find((v) => v.startsWith('Филиал:')) || '';
  const branch = branchLine.replace(/^Филиал:\s*/i, '').trim();
  if (!branch) return null;

  let currentCategory = 'doctor';
  let currentHorizon = '';
  let cabinetLegacyMode = false;
  const rows = [];

  const pushRow = (category, horizon, reception, occupiedVal, loadVal, free, requests, cabinetType, primaryCount, freePP) => {
    const occupied = parseCombinedMetric(occupiedVal);
    const load = parseCombinedMetric(loadVal);
    const primary = parseCombinedMetricOrSingle_(primaryCount);
    rows.push({
      category,
      branch,
      cabinetType: cabinetType || '',
      horizon,
      reception: parseLocaleNumber(reception),
      occupiedCur: occupied.current,
      occupiedUsual: occupied.usual,
      loadCur: load.current,
      loadUsual: load.usual,
      free: parseLocaleNumber(free),
      freePP: parseLocaleNumber(freePP),
      requests: parseLocaleNumber(requests),
      primaryCount: primary.current,
      primaryCountUsual: primary.usual,
    });
  };

  data.forEach((row) => {
    const first = str_(row[0]);
    if (!first) return;

    if (first.includes('Блок 3 дня') || first.includes('Сводный план на 3 дня')) currentHorizon = '3 дня';
    if (first.includes('Блок 7 дней') || first.includes('Сводный план на 7 дней')) currentHorizon = '7 дней';

    if (first.includes('Таблица 1 — Свод по филиалу')) currentCategory = 'doctor';
    if (first.includes('Свод по массажистам')) currentCategory = 'massage';
    if (first.includes('Свод по ФТ')) currentCategory = 'ft';
    if (first.includes('Кабинеты ФТЛ:')) currentCategory = 'cabinet_ftl';
    if (first.includes('Кабинеты Магнит:')) currentCategory = 'cabinet_magnet';
    if (first.includes('Загрузка кабинетов ФТЛ/Магнит')) {
      currentCategory = 'cabinet_legacy';
      cabinetLegacyMode = true;
    }

    // Новый формат: свод по категориям внутри блока горизонта
    if (currentHorizon && (first === 'Врачи' || first === 'Массажисты' || first === 'ФТ' || first === 'Физиотерапия')) {
      const category = first === 'Врачи'
        ? 'doctor'
        : (first === 'Массажисты' ? 'massage' : (first === 'ФТ' ? 'ft' : 'physio'));
      pushRow(category, currentHorizon, row[1], row[2], row[3], row[4], row[5], '', row[6], row[7]);
      return;
    }

    // Новый формат: общий лист non-doctor, категория встроена в колонку филиала
    if ((first.includes('— Массажисты и ФТ') || first.includes('— Физиотерапия')) && (currentHorizon === '3 дня' || currentHorizon === '7 дней')) {
      const category = first.includes('Физиотерапия') ? 'physio' : 'massage';
      pushRow(category, currentHorizon, row[1], row[2], row[3], row[4], row[5], '', row[6], row[7]);
      return;
    }

    // Legacy cabinet separate tables
    if (currentCategory === 'cabinet_ftl' || currentCategory === 'cabinet_magnet') {
      const horizon = str_(row[0]);
      if (horizon !== '3 дня' && horizon !== '7 дней') return;
      pushRow('cabinet', horizon, row[1], row[2], row[3], row[4], row[5], currentCategory === 'cabinet_ftl' ? 'ФТЛ' : 'Магнит', 0, 0);
      return;
    }

    if (currentCategory === 'cabinet_legacy' && cabinetLegacyMode) {
      const horizon = str_(row[1]);
      if (horizon !== '3 дня' && horizon !== '7 дней') return;
      const type = str_(row[0]);
      if (type !== 'ФТЛ' && type !== 'Магнит') return;
      pushRow('cabinet', horizon, 0, row[2], row[3], row[4], row[5], type, 0, 0);
      return;
    }

    // Старый формат (horizon в первом столбце)
    const horizon = first;
    if (horizon !== '3 дня' && horizon !== '7 дней') return;

    if (currentCategory === 'doctor') {
      const occupied = parseCombinedMetric(row[2]);
      const load = parseCombinedMetric(row[4]);
      const primary = parseCombinedMetricOrSingle_(row[8]);
      rows.push({
        category: currentCategory,
        branch,
        horizon,
        reception: parseLocaleNumber(row[1]),
        occupiedCur: occupied.current,
        occupiedUsual: occupied.usual,
        loadCur: load.current,
        loadUsual: load.usual,
        free: parseLocaleNumber(row[5]),
        freePP: parseLocaleNumber(row[6]),
        requests: parseLocaleNumber(row[7]),
        primaryCount: primary.current,
        primaryCountUsual: primary.usual,
      });
      return;
    }

    pushRow(currentCategory, horizon, row[1], row[2], row[3], row[4], row[5], '', row[6], row[7]);
  });

  return rows.length ? { reportDate, reportPeriodLabel, rows } : null;
}

function parseCombinedMetric(value) {
  const text = str_(value);
  const m = text.match(/(-?[\d.,]+)\s*\((-?[\d.,]+)\)/);
  if (!m) return { current: parseLocaleNumber(text), usual: 0 };
  return {
    current: parseLocaleNumber(m[1]),
    usual: parseLocaleNumber(m[2]),
  };
}

function parseCombinedMetricOrSingle_(value) {
  return parseCombinedMetric(value);
}
function parseLocaleNumber(value) {
  const normalized = str_(value).replace(/\s/g, '').replace(',', '.');
  const num = Number(normalized);
  return Number.isFinite(num) ? num : 0;
}
function resetSheetForRender_(sheet) {
  const maxRows = sheet.getMaxRows();
  const maxCols = sheet.getMaxColumns();
  if (maxRows > 0 && maxCols > 0) {
    const allRange = sheet.getRange(1, 1, maxRows, maxCols);
    allRange.breakApart();
    allRange.clearContent();
    allRange.clearFormat();
  }
}

function renderOverallForecastSheet(ss, reportPeriodLabel, clinicRows) {
  const sheet = getOrCreateSheet_(ss, FL2_SHEET_OVERALL_FORECAST);
  resetSheetForRender_(sheet);
  let row = 1;
  const columns = 7;
  const periodLabels = buildHorizonPeriodLabels_(reportPeriodLabel);
  sheet.getRange(row, 1, 1, columns).merge().setValue('Общий план по клиникам').setFontWeight('bold').setBackground('#d9ead3');
  row += 1;
  sheet.getRange(row, 1, 1, columns).merge().setValue(`Сформировано: ${formatDateTimeDDMMYYYY_(new Date())}`).setFontSize(10).setBackground('#f3f8ff');
  row += 2;

  row = renderOverallHorizonTitle_(sheet, row, columns, `Сводный план на 3 дня. Отчетный период: ${periodLabels.period3dLabel || reportPeriodLabel}`);
  row = renderOverallHorizonTable(sheet, row, clinicRows.filter((r) => str_(r.category || 'doctor') === 'doctor'), '3 дня', 'Таблица 1 — Врачи: общий план на 3 дня');
  row += 1;
  row = renderOverallUnifiedAuxTable_(sheet, row, clinicRows.filter((r) => str_(r.category) === 'massage' || str_(r.category) === 'ft'), '3 дня', 'Таблица 2 — Массажисты и ФТ: общий план на 3 дня');
  row += 1;
  row = renderOverallUnifiedAuxTable_(sheet, row, clinicRows.filter((r) => str_(r.category) === 'cabinet' || str_(r.category) === 'physio'), '3 дня', 'Таблица 3 — Физиотерапия: общий план на 3 дня');

  row += 1;
  row = renderOverallHorizonTitle_(sheet, row, columns, `Сводный план на 7 дней. Отчетный период: ${periodLabels.period7dLabel || reportPeriodLabel}`);
  row = renderOverallHorizonTable(sheet, row, clinicRows.filter((r) => str_(r.category || 'doctor') === 'doctor'), '7 дней', 'Таблица 4 — Врачи: общий план на 7 дней');
  row += 1;
  row = renderOverallUnifiedAuxTable_(sheet, row, clinicRows.filter((r) => str_(r.category) === 'massage' || str_(r.category) === 'ft'), '7 дней', 'Таблица 5 — Массажисты и ФТ: общий план на 7 дней');
  row += 1;
  row = renderOverallUnifiedAuxTable_(sheet, row, clinicRows.filter((r) => str_(r.category) === 'cabinet' || str_(r.category) === 'physio'), '7 дней', 'Таблица 6 — Физиотерапия: общий план на 7 дней');

  sheet.autoResizeColumns(1, columns);
}

function renderOverallHorizonTitle_(sheet, row, columns, title) {
  const titleRowRange = sheet.getRange(row, 1, 1, columns);
  const titleRange = sheet.getRange(row, 1, 1, Math.min(4, columns));
  const tailColumns = Math.max(columns - 4, 0);
  titleRowRange.breakApart().clearContent();
  titleRange
    .merge()
    .setValue(title)
    .setFontWeight('bold')
    .setBackground('#eaf3ff');
  if (tailColumns > 0) {
    sheet.getRange(row, 5, 1, tailColumns)
      .setBackground('#eaf3ff')
      .setBorder(false, false, false, false, false, false);
  }
  return row + 1;
}

function renderOverallUnifiedAuxTable_(sheet, row, clinicRows, horizonLabel, title) {
  const columns = 6;
  const header = ['Клиника', 'Приемные (ч)', 'Занятые (ч)', 'Загрузка (%)', 'Свободные (ч)', 'Заявки (шт)'];

  sheet.getRange(row, 1, 1, columns).merge().setValue(title).setFontWeight('bold').setBackground('#cfe2f3');
  row += 1;
  sheet.getRange(row, 1, 1, columns).setValues([header]);
  styleForecastHeaderRow(sheet, row, columns);
  row += 1;

  const aggregated = new Map();
  (clinicRows || [])
    .filter((r) => r.horizon === horizonLabel)
    .forEach((r) => {
      const key = str_(r.branch);
      if (!aggregated.has(key)) {
        aggregated.set(key, {
          branch: str_(r.branch),
          reception: 0,
          occupiedCur: 0,
          occupiedUsual: 0,
          free: 0,
          requests: 0,
        });
      }
      const item = aggregated.get(key);
      item.reception += Number(r.reception) || 0;
      item.occupiedCur += Number(r.occupiedCur) || 0;
      item.occupiedUsual += Number(r.occupiedUsual) || 0;
      item.free += Number(r.free) || 0;
      item.requests += Number(r.requests) || 0;
    });

  const subset = [...aggregated.values()].sort((a, b) => {
    return a.branch.localeCompare(b.branch, 'ru');
  });

  subset.forEach((r) => {
    const loadCur = r.reception ? (r.occupiedCur / r.reception) * 100 : 0;
    const loadUsual = r.reception ? (r.occupiedUsual / r.reception) * 100 : 0;
    const values = [
      r.branch,
      round1_(r.reception),
      `${round1_(r.occupiedCur)} (${round1_(r.occupiedUsual)})`,
      `${round0(loadCur)} (${round0(loadUsual)})`,
      round1_(r.free),
      round1_(r.requests),
    ];
    sheet.getRange(row, 1, 1, columns).setValues([values]);
    styleForecastDataRow(sheet, row, columns);
    styleForecastRow(sheet, row, { occupiedMin: r.occupiedCur * 60, receptionMin: Math.max(1, r.reception * 60) }, { occupiedMin: r.occupiedUsual * 60, receptionMin: Math.max(1, r.reception * 60) }, horizonLabel === '7 дней' ? '7d' : '3d', 4);
    row += 1;
  });

  const reception = subset.reduce((a, r) => a + r.reception, 0);
  const occupiedCur = subset.reduce((a, r) => a + r.occupiedCur, 0);
  const occupiedUsual = subset.reduce((a, r) => a + r.occupiedUsual, 0);
  const weightedCur = reception ? (occupiedCur / reception) * 100 : 0;
  const weightedUsual = reception ? (occupiedUsual / reception) * 100 : 0;
  const free = subset.reduce((a, r) => a + r.free, 0);
  const requests = subset.reduce((a, r) => a + r.requests, 0);

  const totalValues = [
    'ИТОГО',
    round1_(reception),
    `${round1_(occupiedCur)} (${round1_(occupiedUsual)})`,
    `${round0(weightedCur)} (${round0(weightedUsual)})`,
    round1_(free),
    round1_(requests),
  ];
  sheet.getRange(row, 1, 1, columns).setValues([totalValues]);
  styleForecastDataRow(sheet, row, columns);
  styleForecastRow(sheet, row, { occupiedMin: occupiedCur * 60, receptionMin: Math.max(1, reception * 60) }, { occupiedMin: occupiedUsual * 60, receptionMin: Math.max(1, reception * 60) }, horizonLabel === '7 дней' ? '7d' : '3d', 4);
  sheet.getRange(row, 1, 1, columns).setFontWeight('bold').setBackground('#f3f3f3');
  return row + 1;
}

function renderOverallHorizonTable(sheet, row, clinicRows, horizonLabel, title) {
  const columns = 8;
  const header = ['Клиника', 'Приемные (ч)', 'Занятые (ч)', 'Загрузка (%)', 'Свободные (ч)', 'Заявки (шт)', 'Заявки на ПП (шт)', 'Свободные слоты под ПП'];
  sheet.getRange(row, 1, 1, columns).merge().setValue(title).setFontWeight('bold').setBackground('#cfe2f3');
  row += 1;
  sheet.getRange(row, 1, 1, columns).setValues([header]);
  styleForecastHeaderRow(sheet, row, columns);
  row += 1;
  const subset = clinicRows
    .filter((r) => r.horizon === horizonLabel)
    .sort((a, b) => a.branch.localeCompare(b.branch, 'ru'));
  subset.forEach((r) => {
    const values = [
      r.branch,
      round1_(r.reception),
      `${round1_(r.occupiedCur)} (${round1_(r.occupiedUsual)})`,
      `${round0(r.loadCur)} (${round0(r.loadUsual)})`,
      round1_(r.free),
      round1_(r.requests),
      formatMetricWithOptionalBaseline_(r.primaryCount, r.primaryCountUsual, true),
      round1_(r.freePP),
    ];
    sheet.getRange(row, 1, 1, columns).setValues([values]);
    styleForecastDataRow(sheet, row, columns);
    styleForecastRow(sheet, row, { occupiedMin: r.occupiedCur * 60, receptionMin: Math.max(1, r.reception * 60) }, { occupiedMin: r.occupiedUsual * 60, receptionMin: Math.max(1, r.reception * 60) }, horizonLabel === '7 дней' ? '7d' : '3d', 4);
    row += 1;
  });
  const reception = subset.reduce((a, r) => a + r.reception, 0);
  const occupiedCur = subset.reduce((a, r) => a + r.occupiedCur, 0);
  const occupiedUsual = subset.reduce((a, r) => a + r.occupiedUsual, 0);
  const weightedCur = reception ? subset.reduce((a, r) => a + (r.loadCur * r.reception), 0) / reception : 0;
  const weightedUsual = reception ? subset.reduce((a, r) => a + (r.loadUsual * r.reception), 0) / reception : 0;
  const free = subset.reduce((a, r) => a + r.free, 0);
  const requests = subset.reduce((a, r) => a + r.requests, 0);
  const primaryCount = subset.reduce((a, r) => a + (r.primaryCount || 0), 0);
  const primaryCountUsual = subset.reduce((a, r) => a + (r.primaryCountUsual || 0), 0);
  const freePP = subset.reduce((a, r) => a + r.freePP, 0);
  const totalValues = [
    'ИТОГО',
    round1_(reception),
    `${round1_(occupiedCur)} (${round1_(occupiedUsual)})`,
    `${round0(weightedCur)} (${round0(weightedUsual)})`,
    round1_(free),
    round1_(requests),
    formatMetricWithOptionalBaseline_(primaryCount, primaryCountUsual, true),
    round1_(freePP),
  ];
  sheet.getRange(row, 1, 1, columns).setValues([totalValues]);
  styleForecastDataRow(sheet, row, columns);
  styleForecastRow(sheet, row, { occupiedMin: occupiedCur * 60, receptionMin: Math.max(1, reception * 60) }, { occupiedMin: occupiedUsual * 60, receptionMin: Math.max(1, reception * 60) }, horizonLabel === '7 дней' ? '7d' : '3d', 4);
  sheet.getRange(row, 1, 1, columns).setFontWeight('bold').setBackground('#f3f3f3');
  return row + 1;
}
function aggregateForwardCategorySummary_(rowsDoctorAll, employeeSet) {
  const set = employeeSet || new Set();
  const out = {
    c3: emptyForwardMetric(),
    c7: emptyForwardMetric(),
    b3: emptyForwardMetric(),
    b7: emptyForwardMetric(),
  };
  (rowsDoctorAll || []).forEach((r) => {
    if (!set.has(str_(r.doctor))) return;
    addForwardMetric(out.c3, r.c3 || emptyForwardMetric());
    addForwardMetric(out.c7, r.c7 || emptyForwardMetric());
    addForwardMetric(out.b3, r.b3 || emptyForwardMetric());
    addForwardMetric(out.b7, r.b7 || emptyForwardMetric());
  });
  return out;
}

function mergeCabinetTypeSummary_(summary) {
  const ftl = summary && summary.ftl ? summary.ftl : { c3: emptyForwardMetric(), c7: emptyForwardMetric(), b3: emptyForwardMetric(), b7: emptyForwardMetric() };
  const magnet = summary && summary.magnet ? summary.magnet : { c3: emptyForwardMetric(), c7: emptyForwardMetric(), b3: emptyForwardMetric(), b7: emptyForwardMetric() };
  const out = { c3: emptyForwardMetric(), c7: emptyForwardMetric(), b3: emptyForwardMetric(), b7: emptyForwardMetric() };
  addForwardMetric(out.c3, ftl.c3 || emptyForwardMetric());
  addForwardMetric(out.c3, magnet.c3 || emptyForwardMetric());
  addForwardMetric(out.c7, ftl.c7 || emptyForwardMetric());
  addForwardMetric(out.c7, magnet.c7 || emptyForwardMetric());
  addForwardMetric(out.b3, ftl.b3 || emptyForwardMetric());
  addForwardMetric(out.b3, magnet.b3 || emptyForwardMetric());
  addForwardMetric(out.b7, ftl.b7 || emptyForwardMetric());
  addForwardMetric(out.b7, magnet.b7 || emptyForwardMetric());
  return out;
}

function buildCabinetRowsByName_(currentDay, scheduleRows, requests, options) {
  const opts = options || {};
  const includeBaseline = opts.includeBaseline !== false;
  const dailyBuckets = computeCabinetByNameDailyBuckets_(currentDay, 7, scheduleRows, requests);
  const c3 = aggregateCabinetByNameDailyBuckets_(currentDay, 3, dailyBuckets);
  const c7 = aggregateCabinetByNameDailyBuckets_(currentDay, 7, dailyBuckets);
  const b3 = includeBaseline
    ? computeCabinetByNameBaselineMetrics_(currentDay, 3, scheduleRows, requests)
    : new Map();
  const b7 = includeBaseline
    ? computeCabinetByNameBaselineMetrics_(currentDay, 7, scheduleRows, requests)
    : new Map();
  const keys = new Set([...c3.keys(), ...c7.keys(), ...b3.keys(), ...b7.keys()]);
  return [...keys].map((cabinet) => ({
    cabinet,
    c3: c3.get(cabinet) || emptyForwardMetric(),
    c7: c7.get(cabinet) || emptyForwardMetric(),
    b3: b3.get(cabinet) || emptyForwardMetric(),
    b7: b7.get(cabinet) || emptyForwardMetric(),
  })).sort((a, b) => str_(a.cabinet).localeCompare(str_(b.cabinet), 'ru'));
}

function buildCabinetScheduleByNameIndex_(scheduleRows) {
  const map = new Map();
  (scheduleRows || []).forEach((row) => {
    const d = toDate_(row['Дата']);
    const cabinet = str_(row['Кабинет']);
    const type = detectCabinetType_(cabinet);
    const timeType = str_(row['Тип времени']);
    const start = parseTimeToMinutes_(row['Время начала']);
    const end = parseTimeToMinutes_(row['Время окончания']);
    if (!d || !type || !cabinet || timeType !== 'Приемные часы' || start === null || end === null || end <= start) return;
    const key = `${dateKey_(d)}|${cabinet}`;
    if (!map.has(key)) map.set(key, []);
    map.get(key).push({ start, end });
  });
  map.forEach((arr, key) => map.set(key, mergeIntervals_(arr)));
  return map;
}

function buildCabinetRequestByNameIndex_(requests, startDate, endDate) {
  const map = new Map();
  (requests || []).forEach((r) => {
    if (!isActivePlannedStatus(r.status) || !r.startDate) return;
    if (startDate && endDate && (r.startDate < startDate || r.startDate > endDate)) return;
    const cabinet = str_(r.cabinet || r['Кабинет']);
    const type = detectCabinetType_(r.cabinetType || cabinet);
    if (!type || !cabinet) return;
    const key = `${dateKey_(r.startDate)}|${cabinet}`;
    if (!map.has(key)) map.set(key, { intervals: [], reqCount: 0 });
    const e = map.get(key);
    e.intervals.push(requestInterval(r));
    e.reqCount += 1;
  });
  return map;
}

function computeCabinetByNameDailyBuckets_(anchorDate, maxHorizonDays, scheduleRows, requests) {
  const startDate = addDays(anchorDate, 1);
  const endDate = addDays(anchorDate, maxHorizonDays);
  const scheduleIndex = buildCabinetScheduleByNameIndex_(scheduleRows);
  const requestIndex = buildCabinetRequestByNameIndex_(requests, startDate, endDate);
  const out = new Map();
  const touched = new Set();

  scheduleIndex.forEach((workIntervals, key) => {
    const [dKey, cabinet] = key.split('|');
    const day = toDate_(dKey);
    if (!day || day < startDate || day > endDate) return;
    const req = requestIndex.get(key) || { intervals: [], reqCount: 0 };
    touched.add(key);
    const occupied = mergeIntervals_(req.intervals);
    const occupiedWithinWork = intersectIntervals(occupied, workIntervals);
    const free = subtractIntervals(workIntervals, occupiedWithinWork);
    if (!out.has(dKey)) out.set(dKey, []);
    out.get(dKey).push({
      cabinet,
      receptionMin: sumIntervalsMin(workIntervals),
      occupiedMin: sumIntervalsMin(occupiedWithinWork),
      freeMin: sumIntervalsMin(free),
      freePP: 0,
      reqCount: req.reqCount,
      primaryCount: 0,
    });
  });

  requestIndex.forEach((req, key) => {
    if (touched.has(key)) return;
    const [dKey, cabinet] = key.split('|');
    if (!out.has(dKey)) out.set(dKey, []);
    out.get(dKey).push({
      cabinet,
      receptionMin: 0,
      occupiedMin: sumIntervalsMin(mergeIntervals_(req.intervals)),
      freeMin: 0,
      freePP: 0,
      reqCount: req.reqCount,
      primaryCount: 0,
    });
  });

  return out;
}

function aggregateCabinetByNameDailyBuckets_(anchorDate, horizonDays, dailyBuckets) {
  const startDate = addDays(anchorDate, 1);
  const endDate = addDays(anchorDate, horizonDays);
  const out = new Map();

  (dailyBuckets || new Map()).forEach((entries, dKey) => {
    const day = toDate_(dKey);
    if (!day || day < startDate || day > endDate) return;
    (entries || []).forEach((entry) => {
      if (!out.has(entry.cabinet)) out.set(entry.cabinet, emptyForwardMetric());
      addForwardMetric(out.get(entry.cabinet), entry);
    });
  });

  return out;
}

function computeCabinetByNameBaselineMetrics_(currentDay, horizonDays, scheduleRows, requests) {
  const horizonLabel = Number(horizonDays) === 7 ? '7 дней' : '3 дня';
  const index = loadArchiveBaselineIndex_();
  const out = new Map();
  const seen = new Set();

  (scheduleRows || []).forEach((row) => {
    const cabinet = str_(row['Кабинет']);
    const branch = str_(row['Филиал']);
    const type = detectCabinetType_(cabinet);
    if (!cabinet || !branch || !type) return;
    const key = `${branch}|${cabinet}`;
    if (seen.has(key)) return;
    seen.add(key);

    out.set(cabinet, getArchiveBaselineMetric_(index, {
      category: 'physio',
      branch,
      object: cabinet,
      horizon: horizonLabel,
      reportDate: currentDay,
      maxObservations: 6,
    }));
  });

  return out;
}

function detectCabinetType_(cabinetValue) {
  const c = str_(cabinetValue).toLowerCase();
  if (!c) return '';
  if (c.includes('фтл')) return 'ФТЛ';
  if (c.includes('магнит')) return 'Магнит';
  return '';
}

function buildCabinetScheduleIndex_(scheduleRows) {
  const map = new Map();
  (scheduleRows || []).forEach((row) => {
    const d = toDate_(row['Дата']);
    const cabinet = str_(row['Кабинет']);
    const type = detectCabinetType_(cabinet);
    const timeType = str_(row['Тип времени']);
    const start = parseTimeToMinutes_(row['Время начала']);
    const end = parseTimeToMinutes_(row['Время окончания']);
    if (!d || !type || !cabinet || timeType !== 'Приемные часы' || start === null || end === null || end <= start) return;
    const key = `${dateKey_(d)}|${type}|${cabinet}`;
    if (!map.has(key)) map.set(key, []);
    map.get(key).push({ start, end });
  });
  map.forEach((arr, key) => map.set(key, mergeIntervals_(arr)));
  return map;
}

function buildCabinetRequestIndex_(requests, startDate, endDate) {
  const map = new Map();
  (requests || []).forEach((r) => {
    if (!isActivePlannedStatus(r.status) || !r.startDate) return;
    if (startDate && endDate && (r.startDate < startDate || r.startDate > endDate)) return;
    const cabinet = str_(r.cabinet || r['Кабинет']);
    const type = detectCabinetType_(r.cabinetType || cabinet);
    if (!type || !cabinet) return;
    const key = `${dateKey_(r.startDate)}|${type}|${cabinet}`;
    if (!map.has(key)) map.set(key, { intervals: [], reqCount: 0 });
    const e = map.get(key);
    e.intervals.push(requestInterval(r));
    e.reqCount += 1;
  });
  return map;
}

function computeCabinetTypeDailyBuckets_(anchorDate, maxHorizonDays, scheduleRows, requests) {
  const startDate = addDays(anchorDate, 1);
  const endDate = addDays(anchorDate, maxHorizonDays);
  const scheduleIndex = buildCabinetScheduleIndex_(scheduleRows);
  const requestIndex = buildCabinetRequestIndex_(requests, startDate, endDate);

  const out = new Map();
  const touchedReq = new Set();
  scheduleIndex.forEach((workIntervals, key) => {
    const [dKey, type] = key.split('|');
    const day = toDate_(dKey);
    if (!day || day < startDate || day > endDate) return;

    const req = requestIndex.get(key) || { intervals: [], reqCount: 0 };
    touchedReq.add(key);
    const occupied = mergeIntervals_(req.intervals);
    const occupiedWithinWork = intersectIntervals(occupied, workIntervals);
    const free = subtractIntervals(workIntervals, occupiedWithinWork);

    if (!out.has(dKey)) out.set(dKey, []);
    out.get(dKey).push({
      type,
      receptionMin: sumIntervalsMin(workIntervals),
      occupiedMin: sumIntervalsMin(occupiedWithinWork),
      freeMin: sumIntervalsMin(free),
      freePP: 0,
      reqCount: req.reqCount,
      primaryCount: 0,
    });
  });

  requestIndex.forEach((req, key) => {
    if (touchedReq.has(key)) return;
    const [dKey, type] = key.split('|');
    if (!out.has(dKey)) out.set(dKey, []);
    out.get(dKey).push({
      type,
      receptionMin: 0,
      occupiedMin: sumIntervalsMin(mergeIntervals_(req.intervals)),
      freeMin: 0,
      freePP: 0,
      reqCount: req.reqCount,
      primaryCount: 0,
    });
  });

  return out;
}

function aggregateCabinetTypeDailyBuckets_(anchorDate, horizonDays, dailyBuckets) {
  const startDate = addDays(anchorDate, 1);
  const endDate = addDays(anchorDate, horizonDays);
  const out = new Map();

  (dailyBuckets || new Map()).forEach((entries, dKey) => {
    const day = toDate_(dKey);
    if (!day || day < startDate || day > endDate) return;
    (entries || []).forEach((entry) => {
      accumulateForward(out, entry.type, entry, entry.type, '');
    });
  });

  return out;
}

function computeCabinetTypeBaselineMetrics_(currentDay, horizonDays, scheduleRows, requests) {
  const horizonLabel = Number(horizonDays) === 7 ? '7 дней' : '3 дня';
  const index = loadArchiveBaselineIndex_();
  const out = new Map();
  const seen = new Set();

  (scheduleRows || []).forEach((row) => {
    const cabinet = str_(row['Кабинет']);
    const branch = str_(row['Филиал']);
    const type = detectCabinetType_(cabinet);
    if (!cabinet || !branch || !type) return;
    const key = `${branch}|${cabinet}`;
    if (seen.has(key)) return;
    seen.add(key);

    const metric = getArchiveBaselineMetric_(index, {
      category: 'physio',
      branch,
      object: cabinet,
      horizon: horizonLabel,
      reportDate: currentDay,
      maxObservations: 6,
    });
    if (!out.has(type)) out.set(type, emptyForwardMetric());
    addForwardMetric(out.get(type), metric);
  });

  return out;
}

function buildCabinetTypeSummary_(currentDay, scheduleRows, requests, options) {
  const opts = options || {};
  const includeBaseline = opts.includeBaseline !== false;
  const dailyBuckets = computeCabinetTypeDailyBuckets_(currentDay, 7, scheduleRows, requests);
  const c3 = aggregateCabinetTypeDailyBuckets_(currentDay, 3, dailyBuckets);
  const c7 = aggregateCabinetTypeDailyBuckets_(currentDay, 7, dailyBuckets);
  const b3 = includeBaseline
    ? computeCabinetTypeBaselineMetrics_(currentDay, 3, scheduleRows, requests)
    : new Map();
  const b7 = includeBaseline
    ? computeCabinetTypeBaselineMetrics_(currentDay, 7, scheduleRows, requests)
    : new Map();

  const getSummary = (type) => ({
    c3: c3.get(type) ? c3.get(type).metrics : emptyForwardMetric(),
    c7: c7.get(type) ? c7.get(type).metrics : emptyForwardMetric(),
    b3: b3.get(type) || emptyForwardMetric(),
    b7: b7.get(type) || emptyForwardMetric(),
  });

  return {
    ftl: getSummary('ФТЛ'),
    magnet: getSummary('Магнит'),
  };
}

function ensureDoctorScheduleFresh(ss) {
  const doctorScheduleSheet = ss.getSheetByName(SHEET_DOCTOR_SCHEDULE);
  if (!doctorScheduleSheet) {
    throw new Error('Проверьте наличие листа: Обработанный график');
  }
  const builtAt = detectDoctorScheduleBuiltAtFallback(doctorScheduleSheet);
  if (!builtAt) {
    buildDoctorSchedule();
    const doctorScheduleSheet2 = ss.getSheetByName(SHEET_DOCTOR_SCHEDULE);
    const rebuiltAt = detectDoctorScheduleBuiltAtFallback(doctorScheduleSheet2);
    if (!rebuiltAt) {
      throw new Error('Сначала сформируйте лист "Обработанный график" (в последней строке нет системного timestamp)');
    }
    return ensureDoctorScheduleFresh(ss);
  }
}

function detectDoctorScheduleBuiltAtFallback(doctorScheduleSheet) {
  const lastRow = doctorScheduleSheet.getLastRow();
  if (lastRow < 2) return null;
  const marker = doctorScheduleSheet.getRange(lastRow, 1, 1, 10).getDisplayValues()[0];
  const markerKey = str_(marker[0]);
  const markerDate = toDate_(marker[8]);
  if (markerKey !== FL2_SYSTEM_MARKER || !markerDate) return null;
  return markerDate;
}
function sendOverallForecastEmail(ss, reportPeriodLabel) {
  const sheet = ss.getSheetByName(FL2_SHEET_OVERALL_FORECAST);
  const mailingSheet = ss.getSheetByName(FL2_SHEET_MAILING);
  if (!sheet || !mailingSheet) {
    throw new Error('Не найден лист "Общий план" или "Отправка"');
  }
  const mailingRows = getSheetObjects_(mailingSheet);
  const target = mailingRows.find((r) => str_(r['Филиал']) === FL2_SHEET_OVERALL_FORECAST);
  if (!target) throw new Error('Для "Общий план" нет строки в листе Отправка');
  const to = parseEmailList(target['Кому']);
  const cc = parseEmailList(target['Копия']);
  if (!to.length) throw new Error('Для "Общий план" не заполнено поле Кому');
  const subject = `Общий план по клиникам. Отчетный период: ${reportPeriodLabel}`;
  const body = [
    sheetToHtmlTable(sheet, { clinicLinkMap: buildClinicSheetLinkMap_(ss) }),
    '<p><b>Цветовая интерпретация загрузки:</b> для горизонта 3 дня: <span style="background:#ff0000;padding:2px 6px;">красный</span> &lt; 25%, <span style="background:#fff2cc;padding:2px 6px;">желтый</span> 25–40%, белый 40–60%, <span style="background:#d9ead3;padding:2px 6px;">зеленый</span> 60–75%, <span style="background:#f4cccc;padding:2px 6px;">бледно-розовый</span> > 75%. Для горизонта 7 дней: <span style="background:#ff0000;padding:2px 6px;">красный</span> &lt; 20%, <span style="background:#fff2cc;padding:2px 6px;">желтый</span> 20–35%, белый 35–50%, <span style="background:#d9ead3;padding:2px 6px;">зеленый</span> 50–60%, <span style="background:#f4cccc;padding:2px 6px;">бледно-розовый</span> > 60%.</p>',
  ].join('');
  MailApp.sendEmail({
    to: to.join(','),
    cc: cc.join(','),
    subject,
    htmlBody: body,
  });
}

function buildClinicSheetLinkMap_(ss) {
  const map = {};
  if (!ss) return map;
  const spreadsheetUrl = ss.getUrl();
  ss.getSheets().forEach((sheet) => {
    const name = str_(sheet.getName());
    if (!name) return;
    if (name === FL2_SHEET_OVERALL_FORECAST) return;
    if (name === FL2_SHEET_MAILING) return;
    if (name === FL2_SHEET_BATCH_SERVICE) return;
    const a1 = str_(sheet.getRange(1, 1).getDisplayValue());
    if (!(a1 === 'План загрузки' || a1.startsWith('План загрузки. Отчетный период:'))) return;
    map[name] = `${spreadsheetUrl}#gid=${sheet.getSheetId()}`;
  });
  return map;
}

function collectMailingParticipantsByBranch_(ss, branchName) {
  const sheet = ss.getSheetByName(SHEET_DOCTOR_SCHEDULE);
  if (!sheet) {
    return { doctors: [], massage: [], ft: [] };
  }

  const doctorsSet = getDoctorsSetFromEmployeesSheet_(ss);
  const massageSet = getMassageSetFromEmployeesSheet_(ss);
  const ftSet = getFtSetFromEmployeesSheet_(ss);

  const rows = getSheetObjectsByBranch_(sheet, branchName, true);
  const doctors = new Set();
  const massage = new Set();
  const ft = new Set();

  rows.forEach((row) => {
    const employee = str_(row['Сотрудник']);
    if (!employee || employee === '__SYSTEM_TIMESTAMP__') return;
    if (doctorsSet.has(employee)) doctors.add(employee);
    if (massageSet.has(employee)) massage.add(employee);
    if (ftSet.has(employee)) ft.add(employee);
  });

  const toSorted = (set) => [...set].sort((a, b) => a.localeCompare(b, 'ru'));
  return {
    doctors: toSorted(doctors),
    massage: toSorted(massage),
    ft: toSorted(ft),
  };
}

function buildMailingServiceInfoHtml_(ss, branchName, toList, ccList, reportSheet) {
  const participants = collectMailingParticipantsByBranch_(ss, branchName);

  const renderList = (arr) => arr && arr.length ? arr.join(', ') : '—';
  const toText = renderList((toList || []).map((v) => str_(v)).filter((v) => v));
  const ccText = renderList((ccList || []).map((v) => str_(v)).filter((v) => v));

  return [
    '<hr style="border:none;border-top:1px solid #d9d9d9;margin:12px 0;">',
    '<p style="margin:0 0 6px 0;"><b>Служебная информация</b></p>',
    `<p style="margin:0 0 4px 0;"><b>Филиал:</b> ${str_(branchName) || '—'}</p>`,
    `<p style="margin:0 0 4px 0;"><b>Кому:</b> ${toText}</p>`,
    `<p style="margin:0 0 8px 0;"><b>Копия:</b> ${ccText}</p>`,
    `<p style="margin:0 0 4px 0;"><b>Врачи (по "Обработанный график"):</b> ${renderList(participants.doctors)}</p>`,
    `<p style="margin:0 0 4px 0;"><b>Массажисты (по "Обработанный график"):</b> ${renderList(participants.massage)}</p>`,
    `<p style="margin:0;"><b>ФТ (по "Обработанный график"):</b> ${renderList(participants.ft)}</p>`,
  ].join('');
}

function detectPlanBuiltAtFromReportSheet_(sheet) {
  if (!sheet) return null;
  const maxRows = Math.min(sheet.getLastRow(), 6);
  if (maxRows < 1) return null;
  const values = sheet.getRange(1, 1, maxRows, Math.max(1, sheet.getLastColumn())).getDisplayValues();
  for (let i = 0; i < values.length; i += 1) {
    const row = values[i] || [];
    const first = str_(row[0]);
    if (!first.startsWith('Сформировано:')) continue;
    const m = first.match(/Сформировано:\s*(.+)$/i);
    if (!m) continue;
    const d = toDate_(m[1]);
    if (d) return d;
  }
  return null;
}

function extractPlanReportDate_(sheet) {
  if (!sheet) return '';
  const maxRows = Math.min(sheet.getLastRow(), 20);
  if (maxRows < 1) return '';
  const firstCol = sheet.getRange(1, 1, maxRows, 1).getDisplayValues().map((row) => str_(row && row[0]));
  const periodSource = firstCol.find((v) => v.startsWith('Сводный план на 7 дней. Отчетный период:'))
    || firstCol.find((v) => v.startsWith('План загрузки. Отчетный период:'))
    || firstCol.find((v) => v.startsWith('Сводный план на 3 дня. Отчетный период:'))
    || str_(sheet.getRange(1, 1).getDisplayValue());
  const m = periodSource.match(/(\d{2}\.\d{2}\.\d{4})/);
  return m ? m[1] : '';
}

function computeSheetDisplayHash_(sheet) {
  const values = sheet.getDataRange().getDisplayValues();
  const serialized = JSON.stringify(values);
  const digest = Utilities.computeDigest(Utilities.DigestAlgorithm.MD5, serialized, Utilities.Charset.UTF_8);
  return digest.map((b) => (b + 256).toString(16).slice(-2)).join('');
}

function getArchiveSpreadsheet_() {
  return SpreadsheetApp.openById(FL2_PLAN_ARCHIVE_SPREADSHEET_ID);
}

function toArchiveHorizonLabel_(value) {
  const raw = str_(value).toLowerCase();
  if (raw === '3 дня' || raw === '3') return '3 дня';
  if (raw === '7 дней' || raw === '7') return '7 дней';
  return '';
}

function toArchiveMetricFromRow_(row) {
  const receptionHours = Number(str_(row['Приемные (ч)']).replace(',', '.')) || 0;
  const occupiedHours = Number(str_(row['Занятые (ч) текущее']).replace(',', '.')) || 0;
  const freeHours = Number(str_(row['Свободные (ч)']).replace(',', '.')) || 0;
  const primaryCombined = parseCombinedMetricOrSingle_(row['Заявки на ПП (шт)']);
  return {
    receptionMin: receptionHours * 60,
    occupiedMin: occupiedHours * 60,
    freeMin: freeHours * 60,
    reqCount: Number(str_(row['Заявки (шт)']).replace(',', '.')) || 0,
    primaryCount: Number(primaryCombined.current) || 0,
    freePP: Number(str_(row['Свободные слоты под ПП']).replace(',', '.')) || 0,
  };
}

function archiveBaselineKey_(category, branch, objectName, horizon) {
  return [str_(category), str_(branch), str_(objectName), toArchiveHorizonLabel_(horizon)].join('|');
}

function loadArchiveBaselineIndex_() {
  if (FL2_ARCHIVE_BASELINE_CACHE && FL2_ARCHIVE_BASELINE_CACHE.index) return FL2_ARCHIVE_BASELINE_CACHE.index;

  const archive = getArchiveSpreadsheet_();
  const index = new Map();

  Object.keys(FL2_ARCHIVE_CATEGORY_SHEET_MAP).forEach((category) => {
    const sheetName = FL2_ARCHIVE_CATEGORY_SHEET_MAP[category];
    const sheet = archive.getSheetByName(sheetName);
    if (!sheet) return;
    const rows = getSheetObjectsDisplay_(sheet);
    rows.forEach((row) => {
      const rowType = str_(row['ТипСтроки']);
      if (rowType !== 'Детализация') return;
      const branch = str_(row['Филиал']);
      const objectName = str_(row['Объект']);
      const horizon = toArchiveHorizonLabel_(row['Горизонт']);
      const reportDate = toDate_(row['ОтчетДата']);
      if (!branch || !objectName || !horizon || !reportDate) return;

      const key = archiveBaselineKey_(category, branch, objectName, horizon);
      if (!index.has(key)) index.set(key, []);
      index.get(key).push({
        reportDate,
        metric: toArchiveMetricFromRow_(row),
      });
    });
  });

  index.forEach((arr, key) => {
    arr.sort((a, b) => b.reportDate.getTime() - a.reportDate.getTime());
  });

  FL2_ARCHIVE_BASELINE_CACHE = {
    builtAt: new Date(),
    index,
  };
  return index;
}

function getArchiveBaselineMetric_(index, params) {
  const p = params || {};
  const maxObs = Number(p.maxObservations) > 0 ? Number(p.maxObservations) : 6;
  const key = archiveBaselineKey_(p.category, p.branch, p.object, p.horizon);
  const arr = index && index.get(key) ? index.get(key) : [];
  const reportDate = toDate_(p.reportDate);
  const filtered = arr.filter((item) => !reportDate || item.reportDate.getTime() < reportDate.getTime());
  const used = filtered.slice(0, maxObs);

  const logPrefix = `cat=${str_(p.category)}, branch=${str_(p.branch)}, object=${str_(p.object)}, horizon=${str_(p.horizon)}`;
  if (filtered.length < maxObs) {
  }
  if (!used.length) {
    return emptyForwardMetric();
  }

  const out = emptyForwardMetric();
  used.forEach((item) => addForwardMetric(out, item.metric));
  Object.keys(out).forEach((k) => {
    out[k] /= used.length;
  });
  return out;
}

function archivePlanReportsDaily() {
  const src = SpreadsheetApp.getActive();
  const archive = SpreadsheetApp.openById(FL2_PLAN_ARCHIVE_SPREADSHEET_ID);
  const indexSheet = getOrCreateSheet_(archive, 'Индекс плана');

  if (indexSheet.getLastRow() < 1) {
    indexSheet.getRange(1, 1, 1, 7).setValues([['Ключ', 'Лист', 'ОтчетДата', 'МеткаПлана', 'Хэш', 'Обновлено', 'ИсточникКнига']]);
  }

  const categorySheets = {
    doctor: getOrCreateSheet_(archive, 'Архив Врачи'),
    massage: getOrCreateSheet_(archive, 'Архив Массажисты'),
    ft: getOrCreateSheet_(archive, 'Архив ФТ'),
    physio: getOrCreateSheet_(archive, 'Архив Физиотерапия'),
  };

  const dataHeader = ['Ключ', 'Филиал', 'Лист', 'ОтчетДата', 'МеткаПлана', 'Горизонт', 'ТипСтроки', 'Объект', 'Приемные (ч)', 'Занятые (ч) текущее', 'Занятые (ч) обычное', 'Загрузка (%) текущее', 'Загрузка (%) обычное', 'Свободные (ч)', 'Заявки (шт)', 'Заявки на ПП (шт)', 'Свободные слоты под ПП', 'Хэш', 'Обновлено', 'ИсточникКнига'];
  Object.keys(categorySheets).forEach((k) => {
    ensureArchiveDataSheetHeader_(categorySheets[k], dataHeader);
  });

  const indexVals = indexSheet.getLastRow() > 1 ? indexSheet.getRange(2, 1, indexSheet.getLastRow() - 1, 7).getDisplayValues() : [];
  const indexMap = new Map();
  const reportFreshnessMap = new Map();
  indexVals.forEach((r, i) => {
    const key = str_(r[0]);
    const ts = toDate_(r[3]);
    if (key) indexMap.set(key, { row: i + 2, ts });

    const sheetName = str_(r[1]);
    const reportDate = str_(r[2]);
    if (sheetName && reportDate && ts) {
      const reportKey = `${sheetName}|${reportDate}`;
      const prev = reportFreshnessMap.get(reportKey);
      if (!prev || ts.getTime() > prev.getTime()) {
        reportFreshnessMap.set(reportKey, ts);
      }
    }
  });

  const upsertsByCategory = {
    doctor: [],
    massage: [],
    ft: [],
    physio: [],
  };

  const planSheets = src.getSheets();
  planSheets.forEach((sheet) => {
    const values = sheet.getDataRange().getDisplayValues();
    if (!isBranchPlanSheetData_(values)) return;

    const reportDate = extractPlanReportDate_(sheet);
    const builtAt = detectPlanBuiltAtFromReportSheet_(sheet);
    if (!reportDate || !builtAt) return;

    const reportKey = `${sheet.getName()}|${reportDate}`;
    const archivedBuiltAt = reportFreshnessMap.get(reportKey);
    if (archivedBuiltAt && archivedBuiltAt.getTime() >= builtAt.getTime()) return;

    const hash = computeSheetDisplayHash_(sheet);
    const branch = extractBranchFromPlanSheetData_(values) || sheet.getName();
    const detailRows = parsePlanDetailRowsForArchive_(values);
    detailRows.forEach((r) => {
      const category = normalizeArchiveCategory_(r.category);
      if (!category || !r.horizon) return;
      const objectName = r.isTotal ? 'Итого' : str_(r.objectName);
      const key = `${sheet.getName()}|${reportDate}|${category}|${r.horizon}|${objectName}`;
      const idxCurrent = indexMap.get(key);
      if (idxCurrent && idxCurrent.ts && idxCurrent.ts.getTime() >= builtAt.getTime()) return;

      const primaryCount = category === 'doctor' ? round1_(Number(r.primaryCount) || 0) : '';
      const freePP = category === 'doctor' ? round1_(Number(r.freePP) || 0) : '';

      upsertsByCategory[category].push({
        key,
        row: [
          key,
          branch,
          sheet.getName(),
          reportDate,
          formatDateTimeDDMMYYYY_(builtAt),
          r.horizon,
          r.isTotal ? 'Итого' : 'Детализация',
          objectName,
          round1_(Number(r.reception) || 0),
          round1_(Number(r.occupiedCur) || 0),
          round1_(Number(r.occupiedUsual) || 0),
          round1_(Number(r.loadCur) || 0),
          round1_(Number(r.loadUsual) || 0),
          round1_(Number(r.free) || 0),
          round1_(Number(r.requests) || 0),
          primaryCount,
          freePP,
          hash,
          formatDateTimeDDMMYYYY_(new Date()),
          src.getId(),
        ],
        idxRowVals: [key, sheet.getName(), reportDate, formatDateTimeDDMMYYYY_(builtAt), hash, formatDateTimeDDMMYYYY_(new Date()), src.getId()],
      });
    });
  });

  const totalUpserts = Object.keys(upsertsByCategory).reduce((acc, k) => acc + upsertsByCategory[k].length, 0);
  if (!totalUpserts) {
    SpreadsheetApp.getActive().toast('Архив плана: новых изменений нет', MENU_NAME, 5);
    return;
  }

  Object.keys(upsertsByCategory).forEach((category) => {
    upsertArchiveDataRows_(categorySheets[category], upsertsByCategory[category], dataHeader.length);
  });

  Object.keys(upsertsByCategory).forEach((category) => {
    upsertsByCategory[category].forEach((u) => {
      const idxInfo = indexMap.get(u.key);
      if (idxInfo) {
        indexSheet.getRange(idxInfo.row, 1, 1, 7).setValues([u.idxRowVals]);
      } else {
        indexSheet.getRange(indexSheet.getLastRow() + 1, 1, 1, 7).setValues([u.idxRowVals]);
      }
    });
  });

  SpreadsheetApp.getActive().toast(`Архив плана обновлен: ${totalUpserts} строк`, MENU_NAME, 5);
}

function ensureArchiveDataSheetHeader_(sheet, header) {
  if (sheet.getLastRow() < 1) {
    sheet.getRange(1, 1, 1, header.length).setValues([header]);
    return;
  }
  const width = Math.max(1, sheet.getLastColumn());
  const existing = sheet.getRange(1, 1, 1, width).getDisplayValues()[0].map((v) => str_(v));
  if (existing.length < header.length || existing[0] !== 'Ключ' || existing[1] !== 'Филиал') {
    sheet.getRange(1, 1, 1, header.length).setValues([header]);
  }
}

function normalizeArchiveCategory_(category) {
  const c = str_(category);
  if (c === 'doctor') return 'doctor';
  if (c === 'massage') return 'massage';
  if (c === 'ft') return 'ft';
  if (c === 'physio' || c === 'cabinet') return 'physio';
  return '';
}

function extractBranchFromPlanSheetData_(data) {
  const firstCol = (data || []).map((r) => str_(r && r[0]));
  const branchLine = firstCol.find((v) => v.startsWith('Филиал:')) || '';
  return branchLine.replace(/^Филиал:\s*/i, '').trim();
}

function parsePlanDetailRowsForArchive_(data) {
  const rows = [];
  let horizon = '';
  let category = '';
  let expectedFirstCol = '';

  (data || []).forEach((row) => {
    const first = str_(row && row[0]);
    if (!first) return;

    if (first.includes('Сводный план на 3 дня') || first.includes('Блок 3 дня')) {
      horizon = '3 дня';
      category = '';
      expectedFirstCol = '';
      return;
    }
    if (first.includes('Сводный план на 7 дней') || first.includes('Блок 7 дней')) {
      horizon = '7 дней';
      category = '';
      expectedFirstCol = '';
      return;
    }

    if (first.includes('— Врачи (')) {
      category = 'doctor';
      expectedFirstCol = 'Врач';
      return;
    }
    if (first.includes('— Массажисты (')) {
      category = 'massage';
      expectedFirstCol = 'Сотрудник';
      return;
    }
    if (first.includes('— ФТ (')) {
      category = 'ft';
      expectedFirstCol = 'Сотрудник';
      return;
    }
    if (first.includes('— Кабинеты физиотерапии')) {
      category = 'physio';
      expectedFirstCol = 'Кабинет';
      return;
    }

    if (!category || !horizon) return;
    if (first === expectedFirstCol) return;
    if (first.startsWith('Таблица ') || first.startsWith('Сводный план')) return;

    const reception = parseLocaleNumber(row[1]);
    if (!reception && first !== 'ИТОГО') return;
    const occupied = parseCombinedMetric(row[2]);
    const load = parseCombinedMetric(row[3]);
    const free = parseLocaleNumber(row[4]);
    const requests = parseLocaleNumber(row[5]);
    const primaryCountCombined = parseCombinedMetricOrSingle_(row[6]);
    const freePP = parseLocaleNumber(row[7]);
    rows.push({
      category,
      horizon,
      objectName: first,
      isTotal: first === 'ИТОГО',
      reception,
      occupiedCur: occupied.current,
      occupiedUsual: occupied.usual,
      loadCur: load.current,
      loadUsual: load.usual,
      free,
      requests,
      primaryCount: primaryCountCombined.current,
      primaryCountUsual: primaryCountCombined.usual,
      freePP,
    });
  });

  return rows;
}

function upsertArchiveDataRows_(sheet, upserts, width) {
  if (!upserts || !upserts.length) return;
  const lastRow = sheet.getLastRow();
  const vals = lastRow > 1 ? sheet.getRange(2, 1, lastRow - 1, width).getDisplayValues() : [];
  const rowMap = new Map();
  vals.forEach((r, i) => {
    const key = str_(r[0]);
    if (key) rowMap.set(key, i + 2);
  });

  upserts.forEach((u) => {
    const rowNum = rowMap.get(u.key);
    if (rowNum) {
      sheet.getRange(rowNum, 1, 1, width).setValues([u.row]);
    } else {
      sheet.getRange(sheet.getLastRow() + 1, 1, 1, width).setValues([u.row]);
    }
  });
}

function parseEmailList(value) {
  return str_(value)
    .split(',')
    .map((v) => v.trim())
    .filter((v) => v);
}
function sheetToHtmlTable(sheet, options) {
  const opts = options || {};
  const clinicLinkMap = opts.clinicLinkMap || null;
  const range = sheet.getDataRange();
  const values = range.getDisplayValues();
  const backgrounds = range.getBackgrounds();
  const fontWeights = range.getFontWeights();
  const mergedMeta = new Map();
  const mergedSkip = new Set();

  range.getMergedRanges().forEach((mergedRange) => {
    const startRow = mergedRange.getRow() - range.getRow();
    const startCol = mergedRange.getColumn() - range.getColumn();
    const rowSpan = mergedRange.getNumRows();
    const colSpan = mergedRange.getNumColumns();
    mergedMeta.set(`${startRow}:${startCol}`, { rowSpan, colSpan });
    for (let r = startRow; r < startRow + rowSpan; r += 1) {
      for (let c = startCol; c < startCol + colSpan; c += 1) {
        if (r === startRow && c === startCol) continue;
        mergedSkip.add(`${r}:${c}`);
      }
    }
  });

  let currentHorizon = '3d';
  let loadColumnIdx = 4;
  const htmlRows = values
    .map((row, rowIndex) => ({ row, rowIndex }))
    .filter((item) => item.row.some((cell) => str_(cell) !== ''))
    .map((item) => {
      const row = item.row;
      const sourceRowIndex = item.rowIndex;
      const first = str_(row[0]);
      if (first.includes('Таблица 2')) currentHorizon = '3d';
      if (first.includes('Таблица 3')) currentHorizon = '7d';
      if (first === '3 дня') currentHorizon = '3d';
      if (first === '7 дней') currentHorizon = '7d';

      const headerLoadIdx = row.findIndex((cell) => /^Загрузка\s*\(%\)/i.test(str_(cell)) || /^Загрузка/i.test(str_(cell)));
      if (headerLoadIdx >= 0) {
        loadColumnIdx = headerLoadIdx;
      }

      const cells = row.map((cell, idx) => {
        const mergeKey = `${sourceRowIndex}:${idx}`;
        if (mergedSkip.has(mergeKey)) return '';

        const cellText = str_(cell);
        const sourceBg = backgrounds[sourceRowIndex][idx] || '#ffffff';
        const sourceWeight = fontWeights[sourceRowIndex][idx] || 'normal';
        const mergeInfo = mergedMeta.get(mergeKey) || { rowSpan: 1, colSpan: 1 };
        let background = sourceBg;
        if (idx === loadColumnIdx && isLoadMetricCellForEmail_(first, cellText)) {
          const parsed = parseCombinedMetric(cellText);
          background = forecastLoadColorByHorizon(parsed.current, currentHorizon);
        }
        const tag = sourceWeight === 'bold' ? 'th' : 'td';
        const align = idx === 0 ? 'left' : 'center';
        const style = [
          'border:1px solid #cfd8dc',
          'padding:6px 8px',
          `background:${background}`,
          `font-weight:${sourceWeight}`,
          `text-align:${align}`,
          'vertical-align:middle',
        ].join(';');
        let textHtml = cellText || '';
        if (clinicLinkMap && idx === 0 && shouldLinkClinicCellForEmail_(first, cellText, clinicLinkMap)) {
          const href = clinicLinkMap[cellText];
          textHtml = `<a href="${href}" target="_blank" style="color:inherit;text-decoration:none;">${cellText}</a>`;
        }
        const spanAttrs = [
          mergeInfo.colSpan > 1 ? ` colspan="${mergeInfo.colSpan}"` : '',
          mergeInfo.rowSpan > 1 ? ` rowspan="${mergeInfo.rowSpan}"` : '',
        ].join('');
        return `<${tag}${spanAttrs} style="${style}">${textHtml}</${tag}>`;
      }).join('');
      return `<tr>${cells}</tr>`;
    }).join('');
  return `<table style="border-collapse:collapse;font-family:Arial,sans-serif;font-size:13px;line-height:1.35;">${htmlRows}</table>`;
}

function shouldLinkClinicCellForEmail_(firstCellText, cellText, clinicLinkMap) {
  const first = str_(firstCellText);
  const cell = str_(cellText);
  if (!cell || !clinicLinkMap || !clinicLinkMap[cell]) return false;
  if (first === 'Клиника' || first === 'ИТОГО') return false;
  if (first.startsWith('Таблица') || first.startsWith('Блок') || first.startsWith('Общий план') || first.startsWith('Сформировано:')) return false;
  return true;
}

function isLoadMetricCellForEmail_(firstCellText, cellText) {
  const first = str_(firstCellText);
  const value = str_(cellText);
  if (!value) return false;
  if (/^Загрузка/i.test(value)) return false;
  const hasPair = /^-?[\d.,]+\s*\(-?[\d.,]+\)$/.test(value);
  const hasSingleNumber = /^-?[\d.,]+$/.test(value);
  if (!hasPair && !hasSingleNumber) return false;
  if (first === '3 дня' || first === '7 дней' || first === 'ИТОГО') return true;
  if (first.startsWith('Темед')) return true;
  if (first.startsWith('Таблица') || first.startsWith('План') || first.startsWith('Филиал:')) return false;
  return true;
}
function isCompletedStatus(status) {
  return status === 'Проведен прием'
    || status === 'Выполнена'
    || status === 'Пришел';
}

function isPlannedStatus(status) {
  return status === 'Запланирована'
    || status === 'Подтвердил запись'
    || status === 'Недозвон. Отправить смс';
}

function isAllowedProcessedRequestStatus(status) {
  return isPlannedStatus(status);
}

function isActivePlannedStatus(status) {
  return isPlannedStatus(status);
}
function toIntOrNull_(value) {
  if (value === '' || value === null || value === undefined) return null;
  const num = Number(value);
  if (!Number.isFinite(num)) return null;
  return Math.trunc(num);
}

function numOrZero_(value) {
  const num = Number(value);
  return Number.isFinite(num) ? num : 0;
}

function requestInterval(req) {
  if (!req) {
    return { start: 0, end: 1 };
  }
  const start = req.startMin !== undefined ? toIntOrNull_(req.startMin) : parseTimeToMinutes_(req.startTime || req['Время начала']);
  const end = req.endMin !== undefined ? toIntOrNull_(req.endMin) : parseTimeToMinutes_(req.endTime || req['Время окончания']);
  if (start === null || end === null || end <= start) {
    return { start: 0, end: 1 };
  }
  return { start, end };
}

function applyProcessedRequestsIntervalColumnFormat_(sheet, headers) {
  if (!sheet || !Array.isArray(headers) || !headers.length) return;
  const dateHeaders = ['Дата'];
  const timeHeaders = ['Время начала', 'Время окончания'];
  const dataRowCount = Math.max(1, sheet.getMaxRows() - 1);
  dateHeaders.forEach((header) => {
    const colIdx = headers.indexOf(header);
    if (colIdx < 0) return;
    const columnRange = sheet.getRange(2, colIdx + 1, dataRowCount, 1);
    columnRange.clearFormat();
    columnRange.setNumberFormat('@');
  });
  timeHeaders.forEach((header) => {
    const colIdx = headers.indexOf(header);
    if (colIdx < 0) return;
    const columnRange = sheet.getRange(2, colIdx + 1, dataRowCount, 1);
    columnRange.clearFormat();
    columnRange.setNumberFormat('@');
  });
}

function splitRequestDateTimeParts_(startDisplay, endDisplay, startRaw, endRaw) {
  const start = extractDateTimeTokenParts_(startDisplay) || extractDateTimeTokenParts_(startRaw);
  const end = extractDateTimeTokenParts_(endDisplay) || extractDateTimeTokenParts_(endRaw);
  if (!start || !end || !start.dateText || !start.timeText || !end.timeText) {
    return { date: '', startTime: '', endTime: '' };
  }
  return {
    date: start.dateText,
    startTime: start.timeText,
    endTime: end.timeText,
  };
}

function normalizeRequestIntervalParts_(row, startDateRaw, endDateRaw) {
  const startExtracted = extractDateTimeTokenParts_(row['ДатаНачала']);
  const endExtracted = extractDateTimeTokenParts_(row['ДатаОкончания']);
  const dayKey = parseLocalDayKey_(row['Дата'])
    || (startExtracted && startExtracted.dayKey)
    || parseLocalDayKey_(startDateRaw);
  const startCandidate = row['Время начала'] !== undefined && row['Время начала'] !== null && row['Время начала'] !== ''
    ? row['Время начала']
    : (startExtracted && startExtracted.timeText ? startExtracted.timeText : '');
  const endCandidate = row['Время окончания'] !== undefined && row['Время окончания'] !== null && row['Время окончания'] !== ''
    ? row['Время окончания']
    : (endExtracted && endExtracted.timeText ? endExtracted.timeText : '');

  const startMin = parseTimeToMinutes_(startCandidate);
  const endMin = parseTimeToMinutes_(endCandidate);

  if (!dayKey || startMin === null || endMin === null) {
    return { dayKey, startMin, endMin, startTime: str_(startCandidate), endTime: str_(endCandidate), dateText: dayKeyToDateText_(dayKey), error: 'Не удалось определить Дату/Время начала/Время окончания' };
  }
  if (endMin <= startMin) {
    return {
      dayKey,
      startMin,
      endMin,
      startTime: minutesToTimeString_(startMin),
      endTime: minutesToTimeString_(endMin),
      dateText: dayKeyToDateText_(dayKey),
      error: `Время окончания (${minutesToTimeString_(endMin)}) <= времени начала (${minutesToTimeString_(startMin)})`,
    };
  }
  const startDayKey = (startExtracted && startExtracted.dayKey) || parseLocalDayKey_(startDateRaw);
  const endDayKey = (endExtracted && endExtracted.dayKey) || parseLocalDayKey_(endDateRaw);
  if (startDayKey && endDayKey && startDayKey !== endDayKey) {
    return {
      dayKey,
      startMin,
      endMin,
      startTime: minutesToTimeString_(startMin),
      endTime: minutesToTimeString_(endMin),
      dateText: dayKeyToDateText_(dayKey),
      error: `Интервал выходит за границы суток (${formatDateDDMMYYYY_(startDateRaw)} ${minutesToTimeString_(startMin)} -> ${formatDateDDMMYYYY_(endDateRaw)} ${minutesToTimeString_(endMin)})`,
    };
  }

  return {
    dayKey,
    startMin,
    endMin,
    startTime: minutesToTimeString_(startMin),
    endTime: minutesToTimeString_(endMin),
    dateText: dayKeyToDateText_(dayKey),
    error: '',
  };
}

function extractDateTimeTokenParts_(value) {
  const text = str_(value);
  if (text) {
    const dateMatch = text.match(/(\d{1,2})\.(\d{1,2})\.(\d{4})/);
    const timeMatch = text.match(/(\d{1,2}):(\d{2})/);
    if (dateMatch && timeMatch) {
      const day = Number(dateMatch[1]);
      const month = Number(dateMatch[2]);
      const year = Number(dateMatch[3]);
      const hh = Number(timeMatch[1]);
      const mm = Number(timeMatch[2]);
      if (day >= 1 && day <= 31 && month >= 1 && month <= 12 && hh >= 0 && hh <= 23 && mm >= 0 && mm <= 59) {
        const dayKey = `${String(year).padStart(4, '0')}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        return {
          dateText: `${String(day).padStart(2, '0')}.${String(month).padStart(2, '0')}.${String(year).padStart(4, '0')}`,
          dayKey,
          timeText: `${String(hh).padStart(2, '0')}:${String(mm).padStart(2, '0')}`,
        };
      }
    }
  }

  const date = toDate_(value);
  if (!date) return null;
  const dayKey = parseLocalDayKey_(date);
  return {
    dateText: dayKeyToDateText_(dayKey),
    dayKey,
    timeText: Utilities.formatDate(date, FL2_TIMEZONE, 'HH:mm'),
  };
}
function sumIntervalsMin(intervals) {
  return intervals.reduce((acc, i) => acc + (i.end - i.start), 0);
}
function intersectIntervals(a, b) {
  const out = [];
  a.forEach((x) => {
    b.forEach((y) => {
      const start = Math.max(x.start, y.start);
      const end = Math.min(x.end, y.end);
      if (end > start) out.push({ start, end });
    });
  });
  return mergeIntervals_(out);
}
function subtractIntervals(base, sub) {
  let result = [...base];
  sub.forEach((s) => {
    const next = [];
    result.forEach((b) => {
      if (s.end <= b.start || s.start >= b.end) {
        next.push(b);
        return;
      }
      if (s.start > b.start) next.push({ start: b.start, end: s.start });
      if (s.end < b.end) next.push({ start: s.end, end: b.end });
    });
    result = next;
  });
  return mergeIntervals_(result);
}
function addDays(date, days) {
  return new Date(date.getFullYear(), date.getMonth(), date.getDate() + days);
}
function emptyForwardMetric() {
  return { receptionMin: 0, occupiedMin: 0, freeMin: 0, freePP: 0, reqCount: 0, primaryCount: 0 };
}
function addForwardMetric(target, src) {
  Object.keys(target).forEach((k) => {
    target[k] += src[k] || 0;
  });
}
function round0(value) {
  return Math.round(value);
}
function emptyForwardEntry(key) {
  return { branch: key, doctor: '', metrics: emptyForwardMetric() };
}
function accumulateForward(map, key, metric, branch, doctor) {
  if (!map.has(key)) map.set(key, { branch: branch || key, doctor: doctor || '', metrics: emptyForwardMetric() });
  addForwardMetric(map.get(key).metrics, metric);
}
